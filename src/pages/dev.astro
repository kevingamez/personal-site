        color: var(--mute);
      }
      .titlebar .l {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .titlebar .dots {
        display: flex;
        gap: 6px;
      }
      .titlebar .dots span {
        width: 11px;
        height: 11px;
        border-radius: 50%;
      }
      .titlebar .dots span:nth-child(1) {
        background: #ff5f56;
      }
      .titlebar .dots span:nth-child(2) {
        background: #ffbd2e;
      }
      .titlebar .dots span:nth-child(3) {
        background: #27c93f;
      }
      .titlebar .ttl {
        color: #aaa;
        font-size: 11.5px;
      }
      .titlebar .ttl b {
        color: #fff;
