        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 10px;
        font-weight: 600;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .explorer .hd .actions {
        color: var(--mute-2);
        letter-spacing: 0;
        font-weight: 400;
        font-size: 11px;
      }
      .explorer .it {
        padding: 3px 14px;
        color: var(--ink-2);
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        line-height: 1.6;
      }
      .explorer .it:hover {
        background: #1a1a24;
      }
      .explorer .it.fold::before {
        content: "▾";
        color: var(--mute);
        font-size: 9px;
        width: 10px;
      }
      .explorer .it.fold.closed::before {
        content: "▸";
      }
      /* Hide the original colored-square — replaced by material icons (rules below in is:global block) */
      .explorer .it.file::before {
        display: none;
      }
      .explorer .it.indent {
        padding-left: 28px;
      }
      .explorer .it.indent.deep {
        padding-left: 42px;
      }
      .explorer .it.active {
        background: rgba(217, 105, 68, 0.1);
        color: #fff;
        border-left: 2px solid var(--coral);
        padding-left: 12px;
      }
      .explorer .it.active.indent {
        padding-left: 26px;
      }
      .explorer .it.active.indent.deep {
        padding-left: 40px;
      }
      .explorer .it .badge {
        margin-left: auto;
        font-size: 9.5px;
        padding: 1px 5px;
        border-radius: 8px;
        background: var(--coral-soft);
        color: var(--coral);
        letter-spacing: 0.04em;
      }
      .explorer .it .dot {
        margin-left: auto;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
      }
      .explorer .it .dot.warn {
        background: var(--yellow);
      }

      .center {
        display: grid;
        grid-template-rows: 1fr 250px;
        overflow: hidden;
        border-right: 1px solid var(--line);
      }
      @media (max-width: 880px) {
        .center {
          grid-template-rows: auto auto;
        }
      }
      /* workspace switching: hide / show sections by parent state */
      .center.ws-workspace > .scratchpad,
      .center.ws-workspace > .changelog-view {
        display: none;
      }
      .center.ws-scratchpad > .editor,
      .center.ws-scratchpad > .terminal,
      .center.ws-scratchpad > .changelog-view {
        display: none;
      }
      .center.ws-changelog > .editor,
      .center.ws-changelog > .terminal,
      .center.ws-changelog > .scratchpad {
        display: none;
      }
      .center.ws-scratchpad,
      .center.ws-changelog {
        grid-template-rows: 1fr;
      }
      .tabsbar .tab {
        cursor: pointer;
      }
      .term-tabs .tt[data-term] {
        cursor: pointer;
      }
      .term-stream {
        font-family: "JetBrains Mono", monospace;
        font-size: 11.5px;
        line-height: 1.7;
      }
      .term-stream .ln .ts {
        color: var(--mute-2);
      }
      .term-stream .ln .lvl-info {
        color: var(--green);
      }
      .term-stream .ln .lvl-warn {
        color: var(--yellow);
      }
      .term-stream .ln .lvl-err {
        color: var(--red);
      }
      .term-stream .ln .key {
        color: var(--blue);
      }
      .term-stream .ln .vite {
        color: #c47ad9;
      }
      .term-stream .ln .arrow {
        color: var(--coral);
      }

      /* Command palette (⌘P) */
      .palette {
        position: fixed;
        inset: 0;
        z-index: 100;
        background: rgba(0, 0, 0, 0.55);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 80px;
        backdrop-filter: blur(2px);
      }
      .palette[hidden] {
        display: none;
      }
      .palette-card {
        background: var(--panel);
        border: 1px solid var(--line-2);
        border-radius: 10px;
        width: min(560px, 92vw);
        max-height: 60vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 14px 50px rgba(0, 0, 0, 0.7);
        overflow: hidden;
      }
      .palette-input {
        background: transparent;
        border: none;
        outline: none;
        color: var(--ink);
        padding: 14px 18px;
        font-family: "Inter Tight", sans-serif;
        font-size: 14px;
        border-bottom: 1px solid var(--line);
        caret-color: var(--coral);
      }
      .palette-input::placeholder {
        color: var(--mute-2);
      }
      .palette-list {
        overflow-y: auto;
        padding: 6px 0;
        flex: 1;
      }
      .palette-list::-webkit-scrollbar {
