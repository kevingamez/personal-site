---
import Titlebar from "@/components/dev/Titlebar.astro"
import ActivityBar from "@/components/dev/ActivityBar.astro"
import Explorer from "@/components/dev/Explorer.astro"
import EditorPanel from "@/components/dev/EditorPanel.astro"
import TerminalPanel from "@/components/dev/TerminalPanel.astro"
import Workspaces from "@/components/dev/Workspaces.astro"
import Sidebar from "@/components/dev/Sidebar.astro"
import StatusBar from "@/components/dev/StatusBar.astro"
import CommandPalette from "@/components/dev/CommandPalette.astro"
import { buildDevData, serializeDevData } from "@/data/dev"
import "@/styles/dev/index.css"

const buildId = "a7f3c91"
const devDataJson = serializeDevData(await buildDevData())
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>kevin@gamez ~/dev - dev mode</title>
    <meta
      name="description"
      content="Dev-mode portfolio of Kevin Gámez - a tmux/terminal-styled view of the same person."
    />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0a0a0d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://kevingamez.com/dev" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=Inter+Tight:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <!-- Material Symbols (Google) - UI icons for activity bar etc. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      rel="stylesheet"
    />

    <!-- Global rules for elements injected by JS (file tree, palette items, toast etc) -->
    <style is:global>
      /* Smooth arrival from /  → /dev: brief CRT power-on fade-in. */
      body.dev-body-enter {
        animation: dev-body-enter 540ms cubic-bezier(0.2, 0.65, 0.2, 1) both;
      }
      body.dev-body-enter .dev-window {
        animation: dev-window-enter 620ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
        animation-delay: 60ms;
      }
      @keyframes dev-body-enter {
        0% {
          opacity: 0;
          filter: brightness(2.5) blur(6px);
          transform: scale(1.01);
        }
        45% {
          opacity: 1;
        }
        100% {
          opacity: 1;
          filter: brightness(1) blur(0);
          transform: scale(1);
        }
      }
      @keyframes dev-window-enter {
        0% {
          opacity: 0;
          transform: translateY(14px) scale(0.985);
        }
        100% {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        body.dev-body-enter,
        body.dev-body-enter .dev-window {
          animation: none;
        }
      }

      .explorer .it .ico {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        display: inline-block;
        vertical-align: middle;
        pointer-events: none;
      }
      /* Files have no chevron - they have an empty 16px ::before placeholder
         (in the page-scoped CSS) that reserves the chevron column, so file
         icons line up with folder icons at the same depth. */
      .explorer .it .lbl {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
        min-width: 0;
        font-size: 13px;
        line-height: 22px;
      }
      /* Dirty-file marker (modified vs saved) */
      .explorer .it.file.dirty .lbl::after {
        content: "●";
        color: #d96944;
        margin-left: 6px;
        font-size: 8px;
        vertical-align: middle;
      }
      /* File icons in editor tabs (vscode-style) */
      .ed-tabs .et .et-ico,
      .ed-tabs .breadcrumb .bc-ico {
        width: 14px;
        height: 14px;
        vertical-align: middle;
        margin-right: 6px;
        flex-shrink: 0;
        pointer-events: none;
        display: inline-block;
      }
      .ed-tabs .et .et-name {
        display: inline-block;
        vertical-align: middle;
      }
    </style>
  </head>
  <body class="dev-body-enter">
    <div class="desktop">
      <div class="dev-window">
        <Titlebar buildId={buildId} />

        <div class="app">
          <ActivityBar />
          <Explorer />

          <main class="center">
            <EditorPanel />
            <TerminalPanel />
            <Workspaces />
          </main>

          <Sidebar />
        </div>

        <StatusBar />
      </div>
    </div>

    <CommandPalette />

    <script id="dev-data" type="application/json" is:inline set:html={devDataJson} />

    <script>
      import "@/scripts/dev/index.ts"
    </script>
  </body>
</html>
