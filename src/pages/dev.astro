      })()

      /* ─── Shell + virtual filesystem + editor ─── */
      ;(function () {
        const term = document.getElementById("term")
        const input = document.getElementById("cmd")
        const promptEl = document.getElementById("prompt")
        const edTabsEl = document.querySelector(".ed-tabs")
        const edBodyEl = document.querySelector(".ed-body")
        const terminalEl = document.querySelector(".terminal")
        if (!term || !input) return

        // ─── Build-time data injected via <script type="application/json"> ───
        const __DATA = (() => {
          try {
            const el = document.getElementById("dev-data")
            return JSON.parse((el && el.textContent) || "{}")
          } catch {
            return {}
          }
        })()
        const PROJECT_NAME = __DATA.user || "kevingamez"

        // ─── State ───
        let lineNum = 0
        let cwd = [PROJECT_NAME]
        const history = []
        let historyIdx = 0
        let openTabs = []
        let activeTab = null

        // ─── Virtual FS helpers ───
        const _f = (lang, body) => ({ type: "file", lang, body })
        const _d = (children) => ({ type: "dir", children })

        // No demo decorations on real files. Override per-file from data later if needed.
        const FILE_META = {}
        const OUTLINE_MAP = {}
        const folded = new Set()

        // Build the FS from injected data:
        //   {PROJECT_NAME}/                 (the github user)
        //     README.md                     (overview, default open)
        //     {repo-name}/                  (one folder per public repo)
        //       README.md                   (fetched at build time)
        //     {localProjectName}/           (this project's real source files)
        //       src/...
        //       README.md, package.json, ...
        function buildFS() {
          const root = _d({})
          const userDir = _d({})
          root.children[PROJECT_NAME] = userDir

          // Overview README at the user folder root
          if (typeof __DATA.overview === "string") {
            userDir.children["README.md"] = _f("md", __DATA.overview)
          }

          // One folder per public repo
          if (Array.isArray(__DATA.githubRepos)) {
            for (const r of __DATA.githubRepos) {
              if (!r || !r.name) continue
              userDir.children[r.name] = _d({
                "README.md": _f("md", r.readme || ""),
              })
            }
          }

          // Local project files under <localProjectName>/
          const localName = __DATA.localProjectName || "personal-site"
          const localFiles = __DATA.localFiles || {}
          // Make sure the local project folder exists even if files arrive in deep order.
          // If a folder of the same name already came from githubRepos (likely),
          // we merge into it so the local source augments the README.
          let localDir = userDir.children[localName]
          if (!localDir || localDir.type !== "dir") {
            localDir = _d({})
            userDir.children[localName] = localDir
          }
          for (const [path, file] of Object.entries(localFiles)) {
            const parts = path.split("/")
            let cur = localDir
            for (let i = 0; i < parts.length - 1; i++) {
              const seg = parts[i]
              if (!cur.children[seg]) cur.children[seg] = _d({})
              cur = cur.children[seg]
            }
            cur.children[parts[parts.length - 1]] = _f(file.lang, file.body)
          }
          return root
        }
        const FS = buildFS()

        // ─── Persistence (localStorage per file path) ───
        // savedBodies[path] holds the last-saved version of each file (either
        // hydrated from localStorage on first access, or the build-time pristine
        // if there's no saved override). Editor body !== savedBodies[path] → dirty.
        const savedBodies = Object.create(null)
        const lsKey = (rel) => "dev-edit:" + rel
        function hydrateSaved(rel) {
          if (rel in savedBodies) return savedBodies[rel]
          const node = getNode([PROJECT_NAME, ...rel.split("/")])
          if (!node || node.type !== "file") return null
          let stored = null
          try {
            stored = localStorage.getItem(lsKey(rel))
          } catch {
            // localStorage may be blocked; fall back to pristine
          }
          if (stored !== null) {
            node.body = stored
            savedBodies[rel] = stored
          } else {
            savedBodies[rel] = node.body
          }
          return savedBodies[rel]
        }
        function isDirty(rel) {
          const node = getNode([PROJECT_NAME, ...rel.split("/")])
          if (!node || node.type !== "file") return false
          // Hydrate if we haven't yet, so saved baseline is correct.
          if (!(rel in savedBodies)) hydrateSaved(rel)
          return node.body !== savedBodies[rel]
        }
        function saveActive() {
          if (!activeTab) return
          const node = getNode([PROJECT_NAME, ...activeTab.split("/")])
          if (!node || node.type !== "file") return
          try {
            localStorage.setItem(lsKey(activeTab), node.body)
            savedBodies[activeTab] = node.body
            showToast("✓ saved · " + activeTab)
          } catch {
            showToast("⚠ couldn't save (storage blocked)")
          }
          // Refresh dirty indicators
          renderEditor()
          renderExplorer()
        }
        // ─── Path utilities ───
        function resolvePath(p) {
          if (p === undefined) return [...cwd]
          let parts
          if (p === "~" || p === "~/") parts = []
          else if (p.startsWith("~/")) parts = p.slice(2).split("/")
          else if (p.startsWith("/")) parts = p.slice(1).split("/")
          else parts = [...cwd, ...p.split("/")]
          const out = []
          for (const part of parts) {
            if (!part || part === ".") continue
            if (part === "..") {
              out.pop()
              continue
            }
            out.push(part)
          }
          return out
        }
        function getNode(parts) {
          let node = FS
          for (const part of parts) {
            if (!node || node.type !== "dir" || !node.children[part]) return null
            node = node.children[part]
          }
          return node
        }
        function pathDisplay(parts) {
          return "~/" + parts.join("/")
        }
        function updatePrompt() {
          if (promptEl) promptEl.textContent = pathDisplay(cwd) + " $"
        }

        // ─── Output ───
        function addLine(html) {
          const div = document.createElement("div")
          div.className = "ln"
          div.innerHTML = '<span class="gut">' + ++lineNum + '</span><span class="txt">' + html + "</span>"
          term.appendChild(div)
          term.scrollTop = term.scrollHeight
        }
        function err(msg) {
          addLine('<span class="ye">' + esc(msg) + "</span>")
        }
        function clearCursor() {
          term.querySelectorAll(".cu").forEach((c) => c.remove())
        }
        function esc(s) {
          return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
        }

        // ─── Syntax highlighter ───
        const KW_TS =
          /\b(import|export|const|let|var|type|interface|class|extends|implements|return|async|await|function|as|from|if|else|switch|case|break|true|false|null|undefined|new|this|satisfies|typeof|keyof|enum|public|private|protected|readonly|in|of|for|while|do)\b/g
        const KW_RS =
          /\b(pub|fn|let|mut|use|mod|struct|impl|match|return|if|else|true|false|as|trait|crate|self|Self|where|move|async|await|loop|while|for|in|ref)\b/g
        const TY =
          /\b(string|number|boolean|void|any|unknown|never|object|symbol|bigint|Record|Array|Promise|Map|Set|Date|Response|Request|Tool|Project|u8|u16|u32|u64|i8|i16|i32|i64|f32|f64|bool|str|String|Vec|Option|Result|Box)\b/g
        function highlightPlain(text, lang) {
          let s = esc(text)
          s = s.replace(lang === "rs" ? KW_RS : KW_TS, '<span class="kw">$1</span>')
          s = s.replace(TY, '<span class="ty">$1</span>')
          s = s.replace(/\b(\d+(?:\.\d+)?)\b/g, '<span class="num">$1</span>')
          return s
        }
        function highlightCode(line, lang) {
          const out = []
          const n = line.length
          let i = 0
          while (i < n) {
            if (line[i] === "/" && line[i + 1] === "/") {
              out.push('<span class="cm">' + esc(line.slice(i)) + "</span>")
              i = n
            } else if (line[i] === "/" && line[i + 1] === "*") {
              out.push('<span class="cm">' + esc(line.slice(i)) + "</span>")
              i = n
            } else if (line[i] === '"' || line[i] === "'" || line[i] === "`") {
              const q = line[i]
              let j = i + 1
              while (j < n && line[j] !== q) {
                if (line[j] === "\\") j++
                j++
              }
              out.push('<span class="st">' + esc(line.slice(i, Math.min(j + 1, n))) + "</span>")
              i = j + 1
            } else {
              let j = i
              while (j < n && line[j] !== "/" && line[j] !== '"' && line[j] !== "'" && line[j] !== "`") j++
              out.push(highlightPlain(line.slice(i, j), lang))
              i = j
            }
          }
          return out.join("")
        }
        function highlightJson(line) {
          let s = esc(line)
          s = s.replace(/"([^"]*)"(\s*):/g, '<span class="pn">"$1"</span>$2:')
          s = s.replace(/(:\s*)"([^"]*)"/g, '$1<span class="st">"$2"</span>')
          s = s.replace(/\b(true|false|null)\b/g, '<span class="kw">$1</span>')
          s = s.replace(/\b(\d+(?:\.\d+)?)\b/g, '<span class="num">$1</span>')
          return s
        }
        function highlightToml(line) {
          if (/^\s*\[.*\]\s*$/.test(line)) return '<span class="ty">' + esc(line) + "</span>"
          let s = esc(line)
          s = s.replace(/^(\s*)([\w-]+)(\s*=)/, '$1<span class="pn">$2</span>$3')
          s = s.replace(/"([^"]*)"/g, '<span class="st">"$1"</span>')
          s = s.replace(/\b(\d+(?:\.\d+)?)\b/g, '<span class="num">$1</span>')
          s = s.replace(/^(\s*)#(.*)$/, '$1<span class="cm">#$2</span>')
          return s
        }
        function highlight(line, lang) {
          if (lang === "json") return highlightJson(line)
          if (lang === "toml") return highlightToml(line)
          if (lang === "ts" || lang === "rs") return highlightCode(line, lang)
          return esc(line)
        }

        // ─── Editor ───
        function openFile(parts) {
          const node = getNode(parts)
          if (!node || node.type !== "file") return false
          if (parts[0] !== PROJECT_NAME) return false
          const rel = parts.slice(1).join("/")
          // Apply any persisted local edits before showing the file
          hydrateSaved(rel)
          if (!openTabs.includes(rel)) openTabs.push(rel)
          activeTab = rel
          renderEditor()
          renderExplorer()
          renderOutline()
          return true
        }
        function closeTab(rel) {
          openTabs = openTabs.filter((t) => t !== rel)
          if (activeTab === rel) activeTab = openTabs[openTabs.length - 1] || null
          renderEditor()
          renderExplorer()
          renderOutline()
        }
        function renderEditor() {
          if (!edTabsEl || !edBodyEl) return
          // rebuild tabs (preserve grow + breadcrumb at the end)
          edTabsEl.innerHTML = ""
          for (const t of openTabs) {
            const name = t.split("/").pop()
            const div = document.createElement("div")
            const dirty = isDirty(t)
            div.className = "et" + (t === activeTab ? " on" : "") + (dirty ? " dirty" : "")
            // Modified files show a coral dot; clean files show ×.
            // Both stay clickable to close the tab.
            const closer = dirty ? "●" : "×"
            div.innerHTML = esc(name) + ' <span class="x">' + closer + "</span>"
            div.addEventListener("click", (e) => {
              if (e.target.classList && e.target.classList.contains("x")) {
                closeTab(t)
              } else {
                activeTab = t
                renderEditor()
              }
            })
            edTabsEl.appendChild(div)
          }
          const grow = document.createElement("div")
          grow.className = "grow"
          edTabsEl.appendChild(grow)
          const bc = document.createElement("div")
          bc.className = "breadcrumb"
          if (activeTab) {
            const pp = activeTab.split("/")
            const dir = pp.slice(0, -1).join(" › ")
            bc.innerHTML = (dir ? esc(dir) + " › " : "") + "<b>" + esc(pp[pp.length - 1]) + "</b>"
          }
          edTabsEl.appendChild(bc)

          // body — mount CodeMirror for the active file
          edBodyEl.innerHTML = ""
          if (!activeTab) {
            if (window.__cm) window.__cm.destroy()
            edBodyEl.innerHTML = '<div class="ed-empty">no file open. try <span class="ac">cat README.md</span></div>'
            return
          }
          const node = getNode([PROJECT_NAME, ...activeTab.split("/")])
          if (!node || node.type !== "file") return
          // Wait for CodeMirror module (bundled async) before mounting.
          const mountWhenReady = () => {
            if (!window.__cm) {
              window.addEventListener("cm-ready", mountWhenReady, { once: true })
              return
            }
            // Track which path the editor is showing so onChange edits the right node
            const mountedPath = activeTab
            const mountedNode = node
            let lastDirty = isDirty(mountedPath)
            window.__cm.mount(edBodyEl, {
              name: mountedPath,
              lang: mountedNode.lang,
              body: mountedNode.body,
              onChange: (newDoc) => {
                mountedNode.body = newDoc
                const nowDirty = newDoc !== savedBodies[mountedPath]
                if (nowDirty !== lastDirty) {
                  lastDirty = nowDirty
                  // Refresh tab + explorer dirty markers without re-mounting CM
                  refreshTabsDirty()
                  refreshExplorerDirty()
                }
              },
              onCursor: (line, col) => updateStatusPos(line, col),
            })
          }
          mountWhenReady()
        }
        function updateStatusPos(line, col) {
          const el = document.getElementById("status-pos")
          if (el) el.textContent = "UTF-8 · LF · Ln " + line + ", Col " + (col || 1)
        }
        // Update modified markers without remounting the editor (which would
        // reset undo history and cursor position).
        function refreshTabsDirty() {
          if (!edTabsEl) return
          const tabs = edTabsEl.querySelectorAll(".et")
          tabs.forEach((tab, i) => {
            const path = openTabs[i]
            if (!path) return
            const dirty = isDirty(path)
            tab.classList.toggle("dirty", dirty)
            const x = tab.querySelector(".x")
            if (x) x.textContent = dirty ? "●" : "×"
          })
        }
        function refreshExplorerDirty() {
          if (!treeEl) return
          treeEl.querySelectorAll(".it.file").forEach((el) => {
            const path = el.dataset.path
            if (!path) return
            el.classList.toggle("dirty", isDirty(path))
          })
        }

        // ─── Explorer (file tree + outline) ───
        const treeEl = document.getElementById("file-tree")
        const outlineHdEl = document.getElementById("outline-hd")
        const outlineListEl = document.getElementById("outline-list")

        // Material Icon Theme (PKief) served via jsDelivr — same icons VS Code uses
        const ICON_BASE = "https://cdn.jsdelivr.net/gh/PKief/vscode-material-icon-theme@main/icons/"
        function fileIconName(name) {
          const lower = name.toLowerCase()
          if (lower === "package.json") return "nodejs"
          if (lower === "tsconfig.json") return "tsconfig"
          if (lower === "cargo.toml" || lower === "cargo.lock") return "rust"
          if (lower === "bun.lock" || lower === "bun.lockb") return "bun"
          if (lower.startsWith("readme")) return "readme"
          if (lower.startsWith("changelog")) return "changelog"
          if (lower === "license" || lower.startsWith("license")) return "certificate"
          const ext = (name.split(".").pop() || "").toLowerCase()
          const map = {
            ts: "typescript",
