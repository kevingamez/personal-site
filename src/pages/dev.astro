              out.push("<li>" + inlineMd(esc(ln.slice(2))) + "</li>")
            } else if (ln.trim() === "") {
              closeUl()
            } else {
              closeUl()
              out.push("<p>" + inlineMd(esc(ln)) + "</p>")
            }
          }
          closeUl()
          return out.join("")
        }
