<script is:inline>
/* ─── Live sparkline ─── */
(function(){
  const s = document.getElementById('spark');
  if(!s) return;
  const N = 30;
  const arr = Array.from({length:N}, () => 30 + Math.random()*60);
  function render(){
    s.innerHTML = '';
    for(const v of arr){
      const sp = document.createElement('span');
      sp.style.height = v + '%';
      s.appendChild(sp);
    }
  }
  render();
  setInterval(()=>{ arr.shift(); arr.push(40 + Math.random()*55); render(); }, 1800);
})();

/* ─── Heatmap ─── */
(function(){
  const hm = document.getElementById('hm');
  if(!hm) return;
  const total = 7*26;
  for(let i=0;i<total;i++){
    const r = Math.random();
    let cls = '';
    if(r>0.45) cls='l1';
    if(r>0.70) cls='l2';
    if(r>0.88) cls='l3';
    if(r>0.97) cls='l4';
    const d = document.createElement('div');
    if(cls) d.className = cls;
    hm.appendChild(d);
  }
})();

/* ─── Live request log ─── */
(function(){
  const reqs = document.getElementById('reqs');
  if(!reqs) return;
  const paths = ['GET /api/now','GET /api/repos','GET /','GET /life/state','POST /api/eval','GET /work','GET /about','GET /sitemap.xml'];
  setInterval(()=>{
    const p = paths[Math.floor(Math.random()*paths.length)];
    const ms = 20 + Math.floor(Math.random()*180);
    const status = Math.random()>0.95 ? '4xx' : '200';
    const cls = status==='200' ? 'm200' : 'm4xx';
    const r = document.createElement('div');
    r.className = 'r';
    r.innerHTML = '<span class="'+cls+'">'+(status==='200'?'200':'404')+'</span><span class="ms">'+ms+'ms</span><span class="pa">'+p+'</span>';
    reqs.insertBefore(r, reqs.firstChild);
    while(reqs.children.length>7) reqs.removeChild(reqs.lastChild);
  }, 2200);
})();

/* ─── Terminal commands ─── */
(function(){
  const term = document.getElementById('term');
  const input = document.getElementById('cmd');
  if(!term || !input) return;
  let lineNum = 8;
  const responses = {
    about:    ['kevin gámez · founder @ enttor.ai · bogotá', 'eng for 7 yrs, ceo for 2, math nerd for life'],
    work:     ['<span class="ac">enttor.ai</span>      → ad-creative pipelines at scale', '<span class="ac">automata-rs</span>    → wasm cellular automata · ★412', '<span class="ac">fractal-atlas</span>  → glsl deep-zoom · ★189'],
    stack:    ['<span class="di">runtime</span>   node 22 · bun 1.1 · cf workers', '<span class="di">storage</span>   postgres 16 · redis · r2', '<span class="di">models</span>    claude · openai · ollama'],
    repos:    ['kevingamez/<span class="ac">automata-rs</span>      ★412', 'kevingamez/<span class="ac">fractal-atlas</span>    ★189', 'kevingamez/<span class="ac">primes-notebook</span>  ★33', 'kevingamez/<span class="ac">personal-site</span>    ★64'],
    contact:  ['<span class="em">email</span>     hi@kevingamez.com', '<span class="em">github</span>    github.com/kevingamez', '<span class="em">x</span>         x.com/kevin_gamez'],
    life:     ['↗ opening conway\'s game of life… see hero on <span class="ac">/</span>'],
    vim:      ['<span class="ye">E437:</span> terminal capability "cm" required'],
    help:     ['<span class="gr">commands:</span> <span class="ac">about</span> <span class="ac">work</span> <span class="ac">stack</span> <span class="ac">repos</span> <span class="ac">contact</span> <span class="ac">life</span> <span class="ac">vim</span> <span class="ac">clear</span>'],
  };

  function addLine(html){
    const div = document.createElement('div');
    div.className = 'ln';
    div.innerHTML = '<span class="gut">'+(++lineNum)+'</span><span class="txt">'+html+'</span>';
    term.appendChild(div);
    term.scrollTop = term.scrollHeight;
  }
  function clearCursor(){
    [...term.querySelectorAll('.cu')].forEach(c => c.remove());
  }

  input.addEventListener('keydown', (e)=>{
    if(e.key === 'Enter'){
      const v = input.value.trim();
      if(!v) return;
      clearCursor();
      addLine('<span class="pr">~</span> <span class="cmd">'+v+'</span>');
      if(v === 'clear'){
        term.innerHTML = '';
        lineNum = 0;
      } else if(responses[v]){
        for(const line of responses[v]) addLine(line);
      } else {
        addLine('<span class="ye">zsh:</span> command not found: '+v+'  · try <span class="ac">help</span>');
      }
      addLine('<span class="pr">~</span> <span class="cu"></span>');
      input.value = '';
    }
  });
})();
</script>
