          for (const ln of lines) {
            if (ln.startsWith("### ")) {
              closeUl()
              out.push("<h3>" + esc(ln.slice(4)) + "</h3>")
            } else if (ln.startsWith("## ")) {
              closeUl()
              out.push("<h2>" + esc(ln.slice(3)) + "</h2>")
            } else if (ln.startsWith("# ")) {
              closeUl()
              out.push("<h1>" + esc(ln.slice(2)) + "</h1>")
