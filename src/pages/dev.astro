        --ink-2: #c9c9d1;
        --mute: #7d7d88;
        --mute-2: #555560;
        --coral: #d96944;
        --coral-soft: #3a201a;
        --green: #3fb950;
        --yellow: #d29922;
        --red: #f85149;
        --blue: #7a98c4;
        --purple: #c47ad9;
        --string: #a5d6ff;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden;
      }
      body {
