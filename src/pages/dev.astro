---
const buildId = "a7f3c91"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>kevin@gamez ~/dev — dev mode</title>
    <meta
      name="description"
      content="Dev-mode portfolio of Kevin Gámez — a tmux/terminal-styled view of the same person."
    />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0a0a0d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://kevingamez.com/dev" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=Inter+Tight:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #0a0a0d;
        --panel: #10101a;
        --panel-2: #16161e;
        --line: #22222c;
        --line-2: #2a2a36;
        --ink: #e8e8ec;
        --ink-2: #c9c9d1;
        --mute: #7d7d88;
        --mute-2: #555560;
        --coral: #d96944;
        --coral-soft: #3a201a;
        --green: #3fb950;
        --yellow: #d29922;
        --red: #f85149;
        --blue: #7a98c4;
        --purple: #c47ad9;
        --string: #a5d6ff;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden;
      }
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        background-image: radial-gradient(rgba(232, 200, 120, 0.025) 1px, transparent 1px);
        background-size: 3px 3px;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      ::selection {
        background: var(--coral);
        color: #fff;
      }

      .titlebar {
        height: 36px;
        background: #15141a;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 14px;
        font-size: 11px;
        color: var(--mute);
      }
      .titlebar .l {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .titlebar .dots {
        display: flex;
        gap: 6px;
      }
      .titlebar .dots span {
        width: 11px;
        height: 11px;
        border-radius: 50%;
      }
      .titlebar .dots span:nth-child(1) {
        background: #ff5f56;
      }
      .titlebar .dots span:nth-child(2) {
        background: #ffbd2e;
      }
      .titlebar .dots span:nth-child(3) {
        background: #27c93f;
      }
      .titlebar .ttl {
        color: #aaa;
        font-size: 11.5px;
      }
      .titlebar .ttl b {
        color: #fff;
        font-weight: 500;
      }
      .titlebar .r {
        display: flex;
        align-items: center;
        gap: 14px;
        font-size: 11px;
      }
      .titlebar .led {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 8px var(--green);
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        50% {
          opacity: 0.4;
        }
      }
      .titlebar .back {
        padding: 4px 10px;
        border: 1px solid var(--line-2);
        border-radius: 6px;
        color: var(--ink-2);
        transition: all 0.15s;
        font-family: "Inter Tight", sans-serif;
        font-size: 11.5px;
      }
      .titlebar .back:hover {
        border-color: var(--coral);
        color: var(--coral);
      }

      .tabsbar {
        height: 30px;
        background: #0d0d14;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: stretch;
        font-size: 11.5px;
        color: var(--mute);
      }
      .tabsbar .tab {
        padding: 0 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        border-right: 1px solid var(--line);
        cursor: pointer;
        transition: all 0.15s;
      }
      .tabsbar .tab:hover {
        color: var(--ink-2);
        background: #11111a;
      }
      .tabsbar .tab.on {
        color: var(--ink);
        background: var(--bg);
        border-bottom: 2px solid var(--coral);
        position: relative;
        top: 1px;
      }
      .tabsbar .tab .num {
        color: var(--coral);
        font-weight: 600;
      }
      .tabsbar .tab.muted {
        color: var(--mute-2);
      }
      .tabsbar .grow {
        flex: 1;
      }
      .tabsbar .live {
        padding: 0 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--mute);
        font-size: 10.5px;
        letter-spacing: 0.06em;
      }
      .tabsbar .live b {
        color: var(--green);
      }

      .app {
        height: calc(100vh - 36px - 30px - 22px);
        display: grid;
        grid-template-columns: 230px 1fr 320px;
      }
      @media (max-width: 1100px) {
        .app {
          grid-template-columns: 200px 1fr 280px;
        }
      }
      @media (max-width: 880px) {
        .app {
          grid-template-columns: 1fr;
          height: auto;
          overflow: auto;
        }
      }

      .explorer {
        background: var(--panel);
        border-right: 1px solid var(--line);
        padding: 14px 0;
        overflow-y: auto;
        font-size: 12px;
      }
      .explorer .hd {
        padding: 10px 14px 6px;
        color: var(--mute);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 10px;
        font-weight: 600;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .explorer .hd .actions {
        color: var(--mute-2);
        letter-spacing: 0;
        font-weight: 400;
        font-size: 11px;
      }
      .explorer .it {
        padding: 3px 14px;
        color: var(--ink-2);
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        line-height: 1.6;
      }
      .explorer .it:hover {
        background: #1a1a24;
      }
      .explorer .it.fold::before {
        content: "▾";
        color: var(--mute);
        font-size: 9px;
        width: 10px;
      }
      .explorer .it.fold.closed::before {
        content: "▸";
      }
      .explorer .it.file::before {
        content: "";
        width: 11px;
        height: 11px;
        border-radius: 2px;
        display: inline-block;
        margin-left: 14px;
      }
      .explorer .it.file.ts::before {
        background: #3178c6;
      }
      .explorer .it.file.tsx::before {
        background: #3178c6;
      }
      .explorer .it.file.rs::before {
        background: #dea584;
      }
      .explorer .it.file.md::before {
        background: #519aba;
      }
      .explorer .it.file.json::before {
        background: #cbcb41;
      }
      .explorer .it.file.toml::before {
        background: #9c4221;
      }
      .explorer .it.file.css::before {
        background: #563d7c;
      }
      .explorer .it.file.lock::before {
        background: #666;
        border-radius: 50%;
      }
      .explorer .it.indent {
        padding-left: 28px;
      }
      .explorer .it.indent.deep {
        padding-left: 42px;
      }
      .explorer .it.active {
        background: rgba(217, 105, 68, 0.1);
        color: #fff;
        border-left: 2px solid var(--coral);
        padding-left: 12px;
      }
      .explorer .it.active.indent {
        padding-left: 26px;
      }
      .explorer .it.active.indent.deep {
        padding-left: 40px;
      }
      .explorer .it .badge {
        margin-left: auto;
        font-size: 9.5px;
        padding: 1px 5px;
        border-radius: 8px;
        background: var(--coral-soft);
        color: var(--coral);
        letter-spacing: 0.04em;
      }
      .explorer .it .dot {
        margin-left: auto;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
      }
      .explorer .it .dot.warn {
        background: var(--yellow);
      }

      .center {
        display: grid;
        grid-template-rows: 1fr 250px;
        overflow: hidden;
        border-right: 1px solid var(--line);
      }
      @media (max-width: 880px) {
        .center {
          grid-template-rows: auto auto;
        }
      }

      .editor {
        background: var(--bg);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .ed-tabs {
        height: 34px;
        background: #0d0d14;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: stretch;
        font-size: 11.5px;
      }
      .ed-tabs .et {
        padding: 0 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--mute);
        border-right: 1px solid var(--line);
      }
      .ed-tabs .et.on {
        background: var(--bg);
        color: #fff;
        border-bottom: 2px solid var(--coral);
        position: relative;
        top: 1px;
      }
      .ed-tabs .et .x {
        color: var(--mute-2);
        font-size: 11px;
        cursor: pointer;
      }
      .ed-tabs .et:hover .x {
        color: var(--ink-2);
      }
      .ed-tabs .grow {
        flex: 1;
      }
      .ed-tabs .breadcrumb {
        padding: 0 14px;
        display: flex;
        align-items: center;
        gap: 6px;
        color: var(--mute-2);
        font-size: 11px;
      }
      .ed-tabs .breadcrumb b {
        color: var(--ink-2);
        font-weight: 500;
      }
      .ed-body {
        flex: 1;
        overflow: auto;
        padding: 12px 0;
        background: var(--bg);
        position: relative;
      }
      .ed-body::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      .ed-body::-webkit-scrollbar-thumb {
        background: #22222c;
        border-radius: 4px;
      }
      .ed-row {
        display: flex;
        gap: 14px;
        padding: 0 18px;
        line-height: 1.7;
        font-family: "IBM Plex Mono", monospace;
        font-size: 12.5px;
      }
      .ed-row .gut {
        color: #3a3a44;
        width: 34px;
        text-align: right;
        flex-shrink: 0;
        user-select: none;
      }
      .ed-row .gut.cur {
        color: var(--coral);
        font-weight: 600;
      }
      .ed-row .txt {
        flex: 1;
        white-space: pre;
        color: var(--ink-2);
      }
      .ed-row.cur {
        background: rgba(217, 105, 68, 0.05);
      }
      .ed-row .kw {
        color: #ff7b72;
      }
      .ed-row .fn {
        color: #d2a8ff;
      }
      .ed-row .st {
        color: var(--string);
      }
      .ed-row .nm {
        color: #79c0ff;
      }
      .ed-row .cm {
        color: #6e7585;
        font-style: italic;
      }
      .ed-row .num {
        color: #79c0ff;
      }
      .ed-row .pn {
        color: #ffa657;
      }
      .ed-row .op {
        color: #ff7b72;
      }
      .ed-row .ty {
        color: #a5d6ff;
      }
      .ed-row .br {
        color: #8b949e;
      }

      .terminal {
        background: #08080c;
        border-top: 1px solid var(--line);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .term-tabs {
        height: 28px;
        background: #0d0d14;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: stretch;
        font-size: 11px;
        color: var(--mute);
      }
      .term-tabs .tt {
        padding: 0 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        border-right: 1px solid var(--line);
      }
      .term-tabs .tt.on {
        background: #08080c;
        color: var(--ink);
        border-bottom: 2px solid var(--coral);
        position: relative;
        top: 1px;
      }
      .term-tabs .tt::before {
        content: "●";
        font-size: 8px;
      }
      .term-tabs .tt:nth-child(1)::before {
        color: var(--coral);
      }
      .term-tabs .tt:nth-child(2)::before {
        color: var(--green);
      }
      .term-tabs .tt:nth-child(3)::before {
        color: var(--yellow);
      }
      .term-tabs .grow {
        flex: 1;
      }
      .term-tabs .actions {
        padding: 0 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--mute-2);
        font-size: 11px;
      }
      .term-body {
        flex: 1;
        padding: 12px 16px;
        overflow-y: auto;
        font-size: 12.5px;
        color: #e8c878;
      }
      .term-body::-webkit-scrollbar {
        width: 8px;
      }
      .term-body::-webkit-scrollbar-thumb {
        background: #22222c;
        border-radius: 4px;
      }
      .term-body .ln {
        display: flex;
        gap: 10px;
        padding: 0;
        margin-bottom: 1px;
      }
      .term-body .ln .gut {
        color: #3a3a40;
        width: 24px;
        text-align: right;
        flex-shrink: 0;
        user-select: none;
        font-size: 11px;
      }
      .term-body .ln .txt {
        flex: 1;
        white-space: pre-wrap;
        word-break: break-word;
        color: #d4d4dc;
      }
      .pr {
        color: var(--green);
      }
      .cmd {
        color: #fff;
      }
      .ok {
        color: var(--green);
      }
      .ac {
        color: var(--coral);
      }
      .di {
        color: var(--blue);
      }
      .gr {
        color: var(--mute);
      }
      .em {
        color: var(--purple);
      }
      .ye {
        color: var(--yellow);
      }
      .cu {
        display: inline-block;
        width: 8px;
        height: 14px;
        background: #e8c878;
        vertical-align: -2px;
        margin-left: 2px;
        animation: bl 1s steps(2) infinite;
      }
      @keyframes bl {
        50% {
          opacity: 0;
        }
      }
      .term-input {
        padding: 6px 16px 10px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-top: 1px solid var(--line);
        font-size: 12.5px;
        background: #08080c;
      }
      .term-input .pr {
        color: var(--green);
      }
      .term-input input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-family: inherit;
        font-size: inherit;
        caret-color: var(--coral);
      }
      .term-input .hint {
        font-size: 10.5px;
        color: var(--mute-2);
        font-family: "Inter Tight", sans-serif;
      }
      .term-input .pr,
      .term-body .pr {
        white-space: nowrap;
      }
      .term-body .ls-dir {
        color: var(--blue);
        cursor: pointer;
      }
      .term-body .ls-dir:hover {
        color: var(--coral);
      }
      .term-body .ls-file {
        color: var(--ink-2);
        cursor: pointer;
      }
      .term-body .ls-file:hover {
        color: var(--coral);
      }

      .sidebar {
        background: var(--panel);
        overflow-y: auto;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .sidebar::-webkit-scrollbar {
        width: 8px;
      }
      .sidebar::-webkit-scrollbar-thumb {
        background: #22222c;
        border-radius: 4px;
      }
      .panel {
        background: var(--panel-2);
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 14px;
        font-family: "Inter Tight", sans-serif;
      }
      .panel .ph {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        font-family: "JetBrains Mono", monospace;
        font-size: 10.5px;
        color: var(--mute);
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      .panel .ph b {
        color: var(--ink);
        font-weight: 600;
      }
      .panel .ph .pos {
        color: var(--green);
        text-transform: none;
        letter-spacing: 0;
        font-size: 11px;
      }
      .panel .ph .neg {
        color: var(--red);
        text-transform: none;
        letter-spacing: 0;
        font-size: 11px;
      }

      .metric .vl {
        font-family: "JetBrains Mono", monospace;
        font-size: 30px;
        font-weight: 600;
        color: #fff;
        line-height: 1;
      }
      .metric .vl span {
        font-size: 13px;
        color: var(--mute);
        font-weight: 400;
      }
      .metric .sub {
        font-size: 11.5px;
        color: var(--mute);
        margin-top: 6px;
      }
      .row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }

      .spark {
        height: 48px;
        display: flex;
        align-items: flex-end;
        gap: 2px;
        margin-top: 10px;
      }
      .spark span {
        flex: 1;
        background: linear-gradient(180deg, var(--coral), #7a3a25);
        border-radius: 1px;
        transition: height 0.4s;
      }

      .stack-list {
        font-family: "JetBrains Mono", monospace;
        font-size: 11.5px;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .stack-list div {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .stack-list .nm {
        color: var(--ink-2);
      }
      .stack-list .ok {
        color: var(--green);
      }
      .stack-list .warn {
        color: var(--yellow);
      }

      .reqs {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        line-height: 1.85;
        max-height: 140px;
        overflow: hidden;
      }
      .reqs .r {
        display: grid;
        grid-template-columns: 38px 50px 1fr;
        gap: 8px;
        color: var(--ink-2);
      }
      .reqs .r .m200 {
        color: var(--green);
      }
      .reqs .r .m4xx {
        color: var(--yellow);
      }
      .reqs .r .m5xx {
        color: var(--red);
      }
      .reqs .r .ms {
        color: var(--ink-2);
      }
      .reqs .r .pa {
        color: var(--blue);
      }

      .hm {
        display: grid;
        grid-template-columns: repeat(26, 1fr);
        gap: 2px;
        margin-top: 6px;
      }
      .hm div {
        aspect-ratio: 1;
        background: #1a1a22;
        border-radius: 1.5px;
      }
      .hm div.l1 {
        background: #3a201a;
      }
      .hm div.l2 {
        background: #7a3a25;
      }
      .hm div.l3 {
        background: #d96944;
      }
      .hm div.l4 {
        background: #ff8a55;
        box-shadow: 0 0 4px #ff8a55;
      }
      .hm-legend {
        display: flex;
        justify-content: space-between;
        font-size: 9.5px;
        color: var(--mute);
        margin-top: 6px;
        font-family: "JetBrains Mono", monospace;
      }

      .repos {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .repos a {
        display: flex;
        justify-content: space-between;
        padding: 8px 10px;
        border: 1px solid var(--line);
        border-radius: 5px;
        font-size: 11.5px;
        font-family: "JetBrains Mono", monospace;
        color: var(--ink-2);
        transition: all 0.15s;
      }
      .repos a:hover {
        border-color: var(--coral);
        color: #fff;
      }
      .repos .lg {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 5px;
        vertical-align: -1px;
      }
      .repos .star {
        color: var(--mute);
        font-size: 11px;
      }

      .statusbar {
        height: 22px;
        background: var(--coral);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 14px;
        font-size: 10.5px;
        letter-spacing: 0.04em;
      }
      .statusbar .l,
      .statusbar .r {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .statusbar .l span,
      .statusbar .r span {
        display: inline-flex;
        align-items: center;
        gap: 4px;
      }

      .hidden {
        display: none !important;
      }
    </style>
  </head>
  <body>
    <div class="titlebar">
      <div class="l">
        <div class="dots"><span></span><span></span><span></span></div>
        <div class="ttl">kevin@gamez — <b>~/dev</b> — 1452 × 902</div>
      </div>
      <div class="r">
        <span><span class="led"></span>live · build {buildId}</span>
        <a class="back" href="/">← exit dev mode</a>
      </div>
    </div>

    <div class="tabsbar">
      <div class="tab on"><span class="num">1</span>workspace</div>
      <div class="tab muted"><span class="num">2</span>scratchpad</div>
      <div class="tab muted"><span class="num">3</span>changelog</div>
      <div class="grow"></div>
      <div class="live">utc-5 · bogotá · <b>04°35′N</b></div>
    </div>

    <div class="app">
