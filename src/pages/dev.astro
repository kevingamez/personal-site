        function walkDir(node, pathParts, depth, container) {
          // preserve declaration order — the FS is hand-authored to match the original design
          const entries = Object.entries(node.children)
          for (const [name, child] of entries) {
            const childPath = [...pathParts, name]
            const key = childPath.join("/")
            if (child.type === "dir") {
              container.appendChild(makeFolderItem(name, key, depth))
              if (!folded.has(key)) walkDir(child, childPath, depth + 1, container)
