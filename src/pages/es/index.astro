---
const buildId = "a7f3c91"
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kevin Gámez — software, matemáticas, mundos pequeños</title>
    <meta
      name="description"
      content="Kevin Gámez es founding engineer en Enttor, basado en Bogotá. Outbound con IA, automatización de navegador, pipelines de OpenAI, Next.js / NestJS / Postgres."
    />
    <meta name="author" content="Kevin Gámez" />
