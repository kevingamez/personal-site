    <script is:inline>
      /* ─── Game of Life ─── */
      ;(function () {
        const c = document.getElementById("gol")
        if (!c) return
        const ctx = c.getContext("2d")
        const COLS = 64,
          ROWS = 64
        let grid = new Uint8Array(COLS * ROWS)
        let next = new Uint8Array(COLS * ROWS)
        let trail = new Float32Array(COLS * ROWS)
        let gen = 0,
          paused = false
        let lastFrame = performance.now(),
          fps = 0,
          frameCount = 0,
          fpsTimer = 0

        const css = getComputedStyle(document.documentElement)
        const BG = (css.getPropertyValue("--cream-2") || "#f3ede2").trim()
        const FG = (css.getPropertyValue("--ink") || "#1f1d1a").trim()
        const TR = (css.getPropertyValue("--coral") || "#d96944").trim()

        function seed() {
          for (let i = 0; i < grid.length; i++) grid[i] = Math.random() < 0.18 ? 1 : 0
          trail.fill(0)
          gen = 0
        }

        function resize() {
          const r = c.getBoundingClientRect()
          const dpr = Math.min(2, window.devicePixelRatio || 1)
          c.width = Math.max(1, Math.floor(r.width * dpr))
          c.height = Math.max(1, Math.floor(r.height * dpr))
        }

        function step() {
          let alive = 0
          for (let y = 0; y < ROWS; y++) {
            const ym = (y - 1 + ROWS) % ROWS,
              yp = (y + 1) % ROWS
            for (let x = 0; x < COLS; x++) {
              const xm = (x - 1 + COLS) % COLS,
                xp = (x + 1) % COLS
              const n =
                grid[ym * COLS + xm] +
                grid[ym * COLS + x] +
                grid[ym * COLS + xp] +
                grid[y * COLS + xm] +
                grid[y * COLS + xp] +
                grid[yp * COLS + xm] +
                grid[yp * COLS + x] +
                grid[yp * COLS + xp]
              const cur = grid[y * COLS + x]
              const nv = (cur && (n === 2 || n === 3)) || (!cur && n === 3) ? 1 : 0
              if (cur && !nv) trail[y * COLS + x] = 1
              next[y * COLS + x] = nv
              if (nv) alive++
            }
          }
          ;[grid, next] = [next, grid]
          for (let i = 0; i < trail.length; i++) trail[i] *= 0.88
          gen++
          document.getElementById("gol-gen").textContent = gen
          document.getElementById("gol-alive").textContent = alive
        }

        function draw() {
          const W = c.width,
            H = c.height
          const cw = W / COLS,
            ch = H / ROWS
          ctx.fillStyle = BG
          ctx.fillRect(0, 0, W, H)
          for (let y = 0; y < ROWS; y++)
            for (let x = 0; x < COLS; x++) {
              const t = trail[y * COLS + x]
              if (t > 0.08) {
                ctx.globalAlpha = t * 0.55
                ctx.fillStyle = TR
                ctx.fillRect(x * cw, y * ch, cw, ch)
              }
            }
          ctx.globalAlpha = 1
          ctx.fillStyle = FG
          for (let y = 0; y < ROWS; y++)
            for (let x = 0; x < COLS; x++) {
              if (grid[y * COLS + x]) ctx.fillRect(x * cw + 0.5, y * ch + 0.5, cw - 1, ch - 1)
            }
        }

        let acc = 0
        function loop(t) {
          const dt = t - lastFrame
          lastFrame = t
          fpsTimer += dt
          frameCount++
          if (fpsTimer > 500) {
            fps = Math.round((1000 * frameCount) / fpsTimer)
            document.getElementById("gol-fps").textContent = fps
            fpsTimer = 0
            frameCount = 0
          }
          if (!paused) {
            acc += dt
            if (acc >= 130) {
              step()
              acc = 0
            }
          }
          draw()
          requestAnimationFrame(loop)
        }

        const STAMPS = {
          glider: [
            [1, 0],
            [2, 1],
            [0, 2],
            [1, 2],
            [2, 2],
          ],
          lwss: [
            [1, 0],
            [4, 0],
            [0, 1],
            [0, 2],
            [4, 2],
            [0, 3],
            [1, 3],
            [2, 3],
            [3, 3],
          ],
          pulsar: [
            [2, 0],
            [3, 0],
            [4, 0],
            [8, 0],
            [9, 0],
            [10, 0],
            [0, 2],
            [5, 2],
            [7, 2],
            [12, 2],
            [0, 3],
            [5, 3],
            [7, 3],
            [12, 3],
            [0, 4],
            [5, 4],
            [7, 4],
            [12, 4],
            [2, 5],
            [3, 5],
            [4, 5],
            [8, 5],
            [9, 5],
            [10, 5],
            [2, 7],
            [3, 7],
            [4, 7],
            [8, 7],
            [9, 7],
            [10, 7],
            [0, 8],
            [5, 8],
            [7, 8],
            [12, 8],
            [0, 9],
            [5, 9],
            [7, 9],
            [12, 9],
            [0, 10],
            [5, 10],
            [7, 10],
            [12, 10],
            [2, 12],
            [3, 12],
            [4, 12],
            [8, 12],
            [9, 12],
            [10, 12],
          ],
          gun: [
            [24, 0],
            [22, 1],
            [24, 1],
            [12, 2],
            [13, 2],
            [20, 2],
            [21, 2],
            [34, 2],
            [35, 2],
            [11, 3],
            [15, 3],
            [20, 3],
            [21, 3],
            [34, 3],
            [35, 3],
            [0, 4],
            [1, 4],
            [10, 4],
            [16, 4],
            [20, 4],
            [21, 4],
            [0, 5],
            [1, 5],
            [10, 5],
            [14, 5],
            [16, 5],
            [17, 5],
            [22, 5],
            [24, 5],
            [10, 6],
            [16, 6],
            [24, 6],
            [11, 7],
            [15, 7],
            [12, 8],
            [13, 8],
          ],
          clear: "clear",
        }
        let curStamp = "glider"
        document.querySelectorAll(".gol-stamp").forEach((b) => {
          b.addEventListener("click", () => {
            curStamp = b.dataset.stamp
            document.querySelectorAll(".gol-stamp").forEach((x) => x.classList.remove("on"))
            b.classList.add("on")
            if (curStamp === "clear") {
              grid.fill(0)
              trail.fill(0)
              gen = 0
            }
          })
        })
        c.addEventListener("click", (e) => {
          const r = c.getBoundingClientRect()
          const x = Math.floor(((e.clientX - r.left) / r.width) * COLS)
          const y = Math.floor(((e.clientY - r.top) / r.height) * ROWS)
          if (curStamp === "clear") {
            grid.fill(0)
            trail.fill(0)
            gen = 0
            return
          }
          const pat = STAMPS[curStamp] || STAMPS.glider
          for (const [dx, dy] of pat) {
            const xx = (x + dx) % COLS,
              yy = (y + dy + ROWS) % ROWS
            grid[(((yy % ROWS) + ROWS) % ROWS) * COLS + (((xx % COLS) + COLS) % COLS)] = 1
          }
        })
        document.getElementById("gol-pause").addEventListener("click", (e) => {
          paused = !paused
          e.currentTarget.textContent = paused ? "▶" : "⏸"
        })
        document.getElementById("gol-reset").addEventListener("click", seed)

        resize()
        window.addEventListener("resize", resize)
        seed()
        requestAnimationFrame(loop)
      })()

      /* ─── Contribution graph ─── */
      ;(function () {
        const g = document.getElementById("contrib-graph")
        if (!g) return
        const total = 7 * 52
        for (let i = 0; i < total; i++) {
          const r = Math.random()
          let lvl = 0
          if (r > 0.55) lvl = 1
          if (r > 0.78) lvl = 2
          if (r > 0.9) lvl = 3
          if (r > 0.96) lvl = 4
          if (i % 7 === 0 || i % 7 === 6) {
            if (lvl > 0) lvl = Math.max(0, lvl - 1)
          }
          const d = document.createElement("div")
          d.className = "day" + (lvl ? " l" + lvl : "")
          g.appendChild(d)
        }
        document.getElementById("contrib-total").textContent = (1100 + Math.floor(Math.random() * 300)).toLocaleString()
      })()
    </script>
  </body>
