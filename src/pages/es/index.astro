    "url": "https://kevingamez.com",
    "jobTitle": "Founding Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Enttor",
      "url": "https://www.enttor.ai/"
    },
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "Universidad de los Andes"
    },
    "knowsAbout": ["Full-Stack Development", "Artificial Intelligence", "Deep Learning", "TypeScript", "Python", "React", "Next.js", "PyTorch"],
    "sameAs": [
      "https://www.linkedin.com/in/kevin-gamez/",
      "https://github.com/kevingamez",
      "https://www.instagram.com/kevin.gamez/"
    ]
  }
  </script>

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-2EK3T4PNNY"></script>
