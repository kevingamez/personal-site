---
const buildId = "a7f3c91"
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kevin Gámez — software, matemáticas, mundos pequeños</title>
    <meta
      name="description"
      content="Kevin Gámez es ingeniero de software y fundador de enttor.ai en Bogotá. Construye herramientas en la frontera entre sistemas distribuidos y herramientas creativas."
    />
    <meta name="author" content="Kevin Gámez" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#d96944" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href="https://kevingamez.com/es/" />
    <link rel="alternate" hreflang="en" href="https://kevingamez.com/" />
    <link rel="alternate" hreflang="es" href="https://kevingamez.com/es/" />
    <link rel="alternate" hreflang="x-default" href="https://kevingamez.com/" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kevingamez.com/es/" />
    <meta property="og:title" content="Kevin Gámez — software, matemáticas, mundos pequeños" />
    <meta
      property="og:description"
      content="Ingeniero de software y fundador de enttor.ai. Sistemas distribuidos × herramientas creativas."
    />
    <meta property="og:image" content="https://kevingamez.com/og-image.png" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:site_name" content="Kevin Gámez" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Kevin Gámez — software, matemáticas, mundos pequeños" />
    <meta
      name="twitter:description"
      content="Ingeniero de software y fundador de enttor.ai. Sistemas distribuidos × herramientas creativas."
    />
    <meta name="twitter:image" content="https://kevingamez.com/og-image.png" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2EK3T4PNNY" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        dataLayer.push(arguments)
      }
      gtag("js", new Date())
      gtag("config", "G-2EK3T4PNNY")
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --cream: #faf7f0;
        --cream-2: #f3ede2;
        --cream-3: #ebe3d4;
        --ink: #1f1d1a;
        --ink-2: #3a352f;
        --muted: #6b6660;
        --line: rgba(31, 29, 26, 0.1);
        --line-2: rgba(31, 29, 26, 0.18);
        --coral: #d96944;
        --coral-soft: #fce6dc;
        --gold: #c9a35e;
        --green: #5b8a72;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        background: var(--cream);
        color: var(--ink);
        font-family:
          "Inter Tight",
          system-ui,
          -apple-system,
          sans-serif;
        font-size: 16px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      button {
        font-family: inherit;
        cursor: pointer;
      }
      ::selection {
        background: var(--coral);
        color: var(--cream);
      }

      .skip {
        position: absolute;
        left: -9999px;
        top: auto;
        width: 1px;
        height: 1px;
        overflow: hidden;
        z-index: 9999;
      }
      .skip:focus {
        position: fixed;
        left: 16px;
        top: 16px;
        width: auto;
        height: auto;
        overflow: visible;
        padding: 8px 16px;
        background: var(--ink);
        color: var(--cream);
        border-radius: 8px;
        font-size: 14px;
      }

      .wrap {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 28px;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(250, 247, 240, 0.85);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--line);
      }
      .nav-in {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 0;
      }
      .brand {
        font-family: "Instrument Serif", serif;
        font-size: 22px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .brand .dot {
        width: 9px;
        height: 9px;
        background: var(--coral);
        border-radius: 50%;
        display: inline-block;
      }
      .nav-links {
        display: flex;
        gap: 24px;
        font-size: 14px;
        color: var(--muted);
      }
      .nav-links a {
        transition: color 0.2s;
      }
      .nav-links a:hover {
        color: var(--ink);
      }
      .nav-right {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .lang {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 0.08em;
        padding: 6px 8px;
        border-radius: 6px;
        transition: color 0.2s;
      }
      .lang:hover {
        color: var(--ink);
      }
      .lang b {
        color: var(--coral);
        font-weight: 600;
      }
      .dev-toggle {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border: 1px solid var(--line-2);
        border-radius: 999px;
        font-family: "JetBrains Mono", monospace;
        font-size: 11.5px;
        color: var(--ink);
        background: transparent;
        transition: all 0.2s;
      }
      .dev-toggle:hover {
        background: var(--ink);
        color: var(--cream);
        border-color: var(--ink);
      }
      .dev-toggle .led {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--coral);
        box-shadow: 0 0 8px var(--coral);
      }
      .say-hi {
        padding: 8px 16px;
        background: var(--ink);
        color: var(--cream);
        border-radius: 999px;
        font-size: 13px;
        font-weight: 500;
        transition: transform 0.2s;
      }
      .say-hi:hover {
        transform: translateY(-1px);
      }
      @media (max-width: 780px) {
        .nav-links {
          display: none;
        }
      }

      section {
        padding: 88px 0;
        border-bottom: 1px solid var(--line);
        position: relative;
      }
      .sec-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 40px;
        flex-wrap: wrap;
      }
      .sec-num {
        font-family: "JetBrains Mono", monospace;
        font-size: 11.5px;
        color: var(--coral);
        letter-spacing: 0.14em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
      }
      .sec-num::before {
        content: "";
        width: 24px;
        height: 1px;
        background: var(--coral);
      }
      .sec-title {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: clamp(36px, 5vw, 52px);
        line-height: 1.02;
        letter-spacing: -0.02em;
        margin: 0;
        max-width: 18ch;
      }
      .sec-title i {
        font-style: italic;
        color: var(--coral);
      }
      .sec-blurb {
        font-size: 14.5px;
        color: var(--muted);
        max-width: 36ch;
        line-height: 1.55;
        margin: 0;
        text-align: right;
      }
      @media (max-width: 600px) {
        .sec-blurb {
          text-align: left;
        }
      }

      .hero {
        min-height: calc(100svh - 54px);
        display: flex;
        align-items: center;
        padding: 24px 0 56px;
        border-bottom: 1px solid var(--line);
        position: relative;
        overflow: hidden;
      }
      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(to right, rgba(31, 29, 26, 0.05) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(31, 29, 26, 0.05) 1px, transparent 1px);
        background-size: 88px 88px;
        background-position: -1px -1px;
        pointer-events: none;
        z-index: 0;
        mask-image: radial-gradient(ellipse 60% 70% at 25% 50%, transparent 5%, black 90%);
        -webkit-mask-image: radial-gradient(ellipse 60% 70% at 25% 50%, transparent 5%, black 90%);
      }
      .hero > .wrap {
        position: relative;
        z-index: 1;
      }
      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 580px) 1fr;
        gap: 64px;
        align-items: center;
        width: 100%;
      }
      @media (max-width: 900px) {
        .hero {
          min-height: 0;
          padding: 56px 0 88px;
        }
        .hero::before {
          display: none;
        }
        .hero-grid {
          grid-template-columns: 1fr;
          gap: 48px;
        }
      }
      .hello {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--coral-soft);
        color: var(--coral);
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 18px;
      }
      .hello .wave {
        display: inline-block;
        animation: wave 2.4s ease-in-out infinite;
        transform-origin: 70% 70%;
      }
      @keyframes wave {
        0%,
        60%,
        100% {
          transform: rotate(0);
        }
        10% {
          transform: rotate(14deg);
        }
        20% {
          transform: rotate(-8deg);
        }
        30% {
          transform: rotate(14deg);
        }
        40% {
          transform: rotate(-4deg);
        }
        50% {
          transform: rotate(10deg);
        }
      }
      h1.hero-title {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: clamp(56px, 6.6vw, 92px);
        line-height: 0.94;
        letter-spacing: -0.028em;
        margin: 0 0 24px;
        text-wrap: balance;
      }
      h1.hero-title i {
        font-style: italic;
        color: var(--coral);
      }
      .hero-lede {
        font-size: 17px;
        line-height: 1.55;
        color: var(--ink-2);
        max-width: 38ch;
        margin: 0 0 24px;
      }
      .hero-lede b {
        font-weight: 600;
        color: var(--ink);
      }
      .hero-cta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 18px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 500;
        transition:
          transform 0.2s,
          background 0.2s;
      }
      .btn-primary {
        background: var(--ink);
        color: var(--cream);
      }
      .btn-primary:hover {
        transform: translateY(-1px);
      }
      .btn-ghost {
        border: 1px solid var(--line-2);
        color: var(--ink);
      }
      .btn-ghost:hover {
        background: var(--cream-2);
      }
      .meta-row {
        display: flex;
        gap: 18px;
        margin-top: 28px;
        font-family: "JetBrains Mono", monospace;
        font-size: 11.5px;
        color: var(--muted);
        letter-spacing: 0.04em;
        flex-wrap: wrap;
      }
      .meta-row span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .meta-row .live::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 8px var(--green);
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.4;
        }
      }

      .gol-wrap {
        position: relative;
      }
      .gol-cap {
        position: absolute;
        top: -22px;
        left: 0;
        font-family: "JetBrains Mono", monospace;
        font-size: 10.5px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--coral);
      }
      .gol-frame {
        position: relative;
        aspect-ratio: 1/1;
        max-height: calc(100svh - 180px);
        margin-left: auto;
        max-width: 100%;
        border: 1.5px solid var(--ink);
        background: var(--cream-2);
        box-shadow:
          9px 9px 0 var(--ink),
          14px 14px 0 var(--coral);
      }
      @media (max-width: 900px) {
        .gol-frame {
          max-height: none;
          margin-left: 0;
          box-shadow:
            7px 7px 0 var(--ink),
            11px 11px 0 var(--coral);
        }
      }
      .gol-frame canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        cursor: crosshair;
      }
      .gol-readout {
        position: absolute;
        bottom: -32px;
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        font-family: "JetBrains Mono", monospace;
        font-size: 10.5px;
        color: var(--muted);
        letter-spacing: 0.05em;
      }
      .gol-readout b {
        color: var(--ink);
        font-weight: 600;
      }
      .gol-controls {
        position: absolute;
        top: 8px;
        right: 8px;
        display: flex;
        gap: 4px;
      }
      .gol-btn {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        background: rgba(250, 247, 240, 0.85);
        border: 1px solid var(--line-2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        color: var(--ink);
        cursor: pointer;
      }
      .gol-btn:hover {
        background: var(--ink);
        color: var(--cream);
      }
      .gol-stamps {
        position: absolute;
        left: 8px;
        bottom: 8px;
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
        max-width: calc(100% - 16px);
      }
      .gol-stamp {
        padding: 5px 10px;
        border-radius: 999px;
        background: rgba(250, 247, 240, 0.92);
        border: 1px solid var(--line-2);
        font-family: "JetBrains Mono", monospace;
        font-size: 10.5px;
        color: var(--ink);
        cursor: pointer;
        letter-spacing: 0.04em;
      }
      .gol-stamp:hover {
        background: var(--ink);
        color: var(--cream);
        border-color: var(--ink);
      }
      .gol-stamp.on {
        background: var(--coral);
        color: var(--cream);
        border-color: var(--coral);
      }

      .about-grid {
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 60px;
        align-items: start;
      }
      @media (max-width: 900px) {
        .about-grid {
          grid-template-columns: 1fr;
        }
      }
      .portrait {
        width: 100%;
        aspect-ratio: 4/5;
        background: linear-gradient(135deg, var(--cream-3), var(--cream-2));
        border: 1.5px solid var(--ink);
        position: relative;
        overflow: hidden;
        box-shadow: 6px 6px 0 var(--coral);
      }
      .portrait::before {
        content: "K. G.";
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Instrument Serif", serif;
        font-size: 120px;
        color: var(--ink);
        opacity: 0.18;
        font-style: italic;
      }
      .portrait .badge {
        position: absolute;
        bottom: 10px;
        left: 10px;
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        color: var(--ink);
        background: var(--cream);
        padding: 3px 8px;
        letter-spacing: 0.1em;
        border: 1px solid var(--line);
      }
      .about-prose {
        font-size: 18px;
        line-height: 1.65;
        color: var(--ink-2);
      }
      .about-prose p {
        margin: 0 0 18px;
        text-wrap: pretty;
      }
      .about-prose p:first-child {
        font-size: 22px;
        color: var(--ink);
        font-family: "Instrument Serif", serif;
        line-height: 1.4;
      }
      .about-prose p:first-child::first-letter {
        font-size: 1.4em;
        font-style: italic;
        color: var(--coral);
      }
      .about-prose b {
        font-weight: 600;
        color: var(--ink);
      }
      .about-prose i {
        color: var(--coral);
        font-style: italic;
      }
      .quick-facts {
        margin-top: 30px;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
      }
      .qf {
        padding: 14px 16px;
        background: var(--cream-2);
        border-radius: 8px;
        border: 1px solid var(--line);
      }
      .qf .k {
        font-family: "JetBrains Mono", monospace;
        font-size: 10.5px;
        color: var(--muted);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 4px;
      }
      .qf .v {
        font-size: 14.5px;
        color: var(--ink);
        font-weight: 500;
      }

      .skill-cluster {
        margin-bottom: 28px;
      }
      .skill-cluster .label {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: var(--coral);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 12px;
      }
      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .chip {
        padding: 7px 13px;
        background: var(--cream);
        border: 1px solid var(--line-2);
        border-radius: 999px;
        font-size: 13px;
        color: var(--ink);
        transition: all 0.15s;
        cursor: default;
      }
      .chip:hover {
        background: var(--ink);
        color: var(--cream);
        border-color: var(--ink);
        transform: translateY(-1px);
      }
      .chip.hot {
        background: var(--coral-soft);
        color: var(--coral);
        border-color: transparent;
        font-weight: 500;
      }
      .chip.hot:hover {
        background: var(--coral);
        color: var(--cream);
      }

      .timeline {
        position: relative;
      }
      .timeline::before {
        content: "";
        position: absolute;
        left: 120px;
        top: 6px;
        bottom: 6px;
        width: 1px;
        background: var(--line-2);
      }
      @media (max-width: 700px) {
        .timeline::before {
          left: 8px;
        }
      }
      .tl-item {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 32px;
        padding: 18px 0;
        position: relative;
      }
      @media (max-width: 700px) {
        .tl-item {
          grid-template-columns: 1fr;
          gap: 8px;
          padding-left: 32px;
        }
      }
      .tl-year {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: var(--muted);
        padding-top: 4px;
        text-align: right;
      }
      @media (max-width: 700px) {
        .tl-year {
          text-align: left;
        }
      }
      .tl-content {
        position: relative;
        padding-left: 24px;
      }
      @media (max-width: 700px) {
        .tl-content {
          padding-left: 0;
        }
      }
      .tl-content::before {
        content: "";
        position: absolute;
        left: -7px;
        top: 8px;
        width: 13px;
        height: 13px;
        border-radius: 50%;
        background: var(--cream);
        border: 2px solid var(--ink);
      }
      @media (max-width: 700px) {
        .tl-content::before {
          left: -30px;
        }
      }
      .tl-item.now .tl-content::before {
        background: var(--coral);
        border-color: var(--coral);
        box-shadow: 0 0 0 4px var(--coral-soft);
      }
      .tl-role {
        font-family: "Instrument Serif", serif;
        font-size: 24px;
        line-height: 1.1;
        margin: 0 0 4px;
      }
      .tl-role .at {
        color: var(--coral);
        font-style: italic;
      }
      .tl-meta {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 0.04em;
        margin-bottom: 10px;
      }
      .tl-desc {
        font-size: 14.5px;
        color: var(--ink-2);
        line-height: 1.55;
        margin: 0;
        max-width: 60ch;
      }

      .proj-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 22px;
      }
      @media (max-width: 780px) {
        .proj-grid {
          grid-template-columns: 1fr;
        }
      }
      .proj {
        background: var(--cream-2);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 26px;
        position: relative;
        transition: all 0.25s;
        overflow: hidden;
      }
      .proj:hover {
        transform: translateY(-3px);
        box-shadow: 0 14px 30px rgba(31, 29, 26, 0.08);
        border-color: var(--line-2);
      }
      .proj.featured {
        grid-column: span 2;
        background: var(--ink);
        color: var(--cream);
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 30px;
        align-items: center;
      }
      @media (max-width: 780px) {
        .proj.featured {
          grid-template-columns: 1fr;
          grid-column: span 1;
        }
      }
