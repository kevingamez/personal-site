          grid-template-columns: 1fr;
        }
      }
      .gh-card {
        background: var(--cream-2);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 22px;
      }
      .gh-card-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 16px;
      }
      .gh-card-head h3 {
        font-family: "Instrument Serif", serif;
        font-size: 22px;
        font-weight: 400;
        margin: 0;
      }
