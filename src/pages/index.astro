    <section id="about">
      <div class="wrap">
        <div class="sec-head">
          <div>
            <div class="sec-num">§01 — About</div>
            <h2 class="sec-title">A small studio of <i>one</i>, mostly happy.</h2>
          </div>
          <p class="sec-blurb">
            Founding engineer, full-stack, deep-learning grad. Short version below; long version over coffee.
          </p>
