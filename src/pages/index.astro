---
import PortfolioLayout from '../components/PortfolioLayout.tsx';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kevin Gamez | Founding Engineer at Enttor — Full-Stack, AI & Deep Learning</title>
  <meta name="description" content="Kevin Gamez is a Founding Engineer at Enttor specializing in full-stack development, AI pipelines, browser automation, and deep learning. MSc from Universidad de los Andes, Bogota, Colombia." />
  <meta name="keywords" content="Kevin Gamez, Founding Engineer, Enttor, Full-Stack Developer, AI Engineer, Deep Learning, TypeScript, React, Next.js, Python, PyTorch, Bogota, Colombia" />
  <meta name="author" content="Kevin Gamez" />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#3b82f6" />
  <link rel="canonical" href="https://kevingamez.com/" />
  <link rel="alternate" hreflang="en" href="https://kevingamez.com/" />
  <link rel="alternate" hreflang="es" href="https://kevingamez.com/es/" />
  <link rel="alternate" hreflang="x-default" href="https://kevingamez.com/" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://kevingamez.com/" />
  <meta property="og:title" content="Kevin Gamez | Founding Engineer at Enttor" />
  <meta property="og:description" content="Full-stack engineer specializing in AI pipelines, browser automation, and deep learning. MSc from Universidad de los Andes." />
  <meta property="og:image" content="https://kevingamez.com/og-image.png" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:locale:alternate" content="es_CO" />
  <meta property="og:site_name" content="Kevin Gamez" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content="https://kevingamez.com/" />
  <meta name="twitter:title" content="Kevin Gamez | Founding Engineer at Enttor" />
  <meta name="twitter:description" content="Full-stack engineer specializing in AI pipelines, browser automation, and deep learning. MSc from Universidad de los Andes." />
  <meta name="twitter:image" content="https://kevingamez.com/og-image.png" />

  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Kevin Gamez",
    "url": "https://kevingamez.com",
    "jobTitle": "Founding Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Enttor",
      "url": "https://www.enttor.ai/"
    },
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "Universidad de los Andes"
    },
    "knowsAbout": ["Full-Stack Development", "Artificial Intelligence", "Deep Learning", "TypeScript", "Python", "React", "Next.js", "PyTorch"],
    "sameAs": [
      "https://www.linkedin.com/in/kevin-gamez/",
      "https://github.com/kevingamez",
      "https://www.instagram.com/kevin.gamez/"
    ]
  }
  </script>

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-2EK3T4PNNY"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-2EK3T4PNNY');
  </script>

  <!-- Geist Font (preloaded) -->
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/geist@1.2.0/dist/fonts/geist-sans/style.min.css" as="style" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.2.0/dist/fonts/geist-sans/style.min.css" />

  <!-- Smooth scroll CSS -->
  <style>
    html {
      scroll-behavior: smooth;
      scroll-snap-type: y proximity;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: 'Geist Sans', sans-serif;
      overflow-x: hidden;
    }

    section {
      scroll-snap-align: start;
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
        scroll-snap-type: none;
      }
    }
    
    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
    }
    
    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }
    
    ::-webkit-scrollbar-thumb {
      background: #3b82f6;
      border-radius: 4px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
      background: #2563eb;
    }
  </style>
</head>
<body>
  <a href="#about" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:9999;padding:8px 16px;background:#3b82f6;color:#fff;text-decoration:none;font-family:sans-serif;font-size:14px;border-radius:4px;" onfocus="this.style.position='fixed';this.style.left='16px';this.style.top='16px';this.style.width='auto';this.style.height='auto';this.style.overflow='visible'" onblur="this.style.position='absolute';this.style.left='-9999px';this.style.width='1px';this.style.height='1px';this.style.overflow='hidden'">Skip to content</a>
  <PortfolioLayout client:load />
</body>
</html>
