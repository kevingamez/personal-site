---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>500 - Kevin Gámez</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --cream: #faf7f0;
        --ink: #1f1d1a;
        --ink-2: #3a352f;
        --muted: #6b6660;
        --line-2: rgba(31, 29, 26, 0.18);
        --coral: #d96944;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background: var(--cream);
        color: var(--ink);
        font-family:
          "Inter Tight",
          system-ui,
          -apple-system,
          sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 24px;
      }
      .wrap {
        max-width: 560px;
      }
      .tag {
        font-family: "JetBrains Mono", monospace;
        font-size: 11.5px;
        color: var(--coral);
        letter-spacing: 0.14em;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
      }
      .tag::before {
        content: "";
        width: 24px;
        height: 1px;
        background: var(--coral);
      }
      h1 {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: clamp(80px, 18vw, 160px);
        line-height: 0.95;
        letter-spacing: -0.025em;
        margin: 0 0 8px;
      }
      h1 i {
        font-style: italic;
        color: var(--coral);
      }
      h2 {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: clamp(28px, 4.4vw, 40px);
        line-height: 1.05;
        margin: 0 0 18px;
        letter-spacing: -0.01em;
        color: var(--ink);
      }
      h2 i {
        font-style: italic;
        color: var(--coral);
      }
      p {
        font-size: 17px;
        color: var(--ink-2);
        line-height: 1.55;
        margin: 0 0 28px;
        text-wrap: balance;
      }
      .ctas {
        display: inline-flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 18px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
        font-family: inherit;
        border: none;
        transition:
          transform 0.2s,
          background 0.2s;
      }
      .btn-primary {
        background: var(--ink);
        color: var(--cream);
      }
      .btn-primary:hover {
        transform: translateY(-1px);
      }
      .btn-ghost {
        border: 1px solid var(--line-2);
        background: transparent;
        color: var(--ink);
      }
      .btn-ghost:hover {
        background: #f3ede2;
      }
      .console {
        margin-top: 40px;
        padding: 14px 16px;
        background: rgba(31, 29, 26, 0.04);
        border: 1px solid var(--line-2);
        border-radius: 10px;
        font-family: "JetBrains Mono", monospace;
        font-size: 11.5px;
        color: var(--ink-2);
        text-align: left;
        line-height: 1.7;
      }
      .console .ln {
        display: flex;
        gap: 10px;
      }
      .console .ln .nm {
        color: var(--muted);
        width: 14px;
        text-align: right;
        flex-shrink: 0;
      }
      .console .err {
        color: var(--coral);
      }
      .console .ok {
        color: #5a8a4f;
      }
      .console .key {
        color: var(--ink);
        font-weight: 600;
      }
      .console .mute {
        color: var(--muted);
      }
      #ref {
        font-variant-numeric: tabular-nums;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="tag">§ - Broken</div>
      <h1>5<i>0</i>0</h1>
      <h2>Something <i>misbehaved.</i></h2>
      <p>
        An error slipped through. The site didn't plan for this one. Try again, head home, or refresh and pretend
        nothing happened.
      </p>
      <div class="ctas">
        <a class="btn btn-primary" href="/">← Back home</a>
        <button class="btn btn-ghost" type="button" id="refresh-btn">↻ Refresh</button>
        <a class="btn btn-ghost" href="/dev/">Open dev mode</a>
      </div>

      <div class="console" role="presentation">
        <div class="ln">
          <span class="nm">1</span><span
            ><span class="key">$</span> <span class="mute">curl -i kevingamez.com</span></span
          >
        </div>
        <div class="ln"><span class="nm">2</span><span class="err">HTTP/1.1 500 Internal Server Error</span></div>
        <div class="ln">
          <span class="nm">3</span><span class="mute">x-trace-id: <span id="ref">———————</span></span>
        </div>
        <div class="ln"><span class="nm">4</span><span class="mute">x-build: a7f3c91 · static · vercel</span></div>
        <div class="ln">
          <span class="nm">5</span><span
            ><span class="key">$</span> <span class="mute">retry --backoff exponential</span></span
          >
        </div>
        <div class="ln"><span class="nm">6</span><span class="ok">… or just go home, life is short.</span></div>
      </div>
    </div>

    <script src="/error-page.js" defer is:inline></script>
  </body>
</html>
