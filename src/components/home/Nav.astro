---
import type { HomeStrings } from "@/content/home"

interface Props {
  meta: HomeStrings["meta"]
  t: HomeStrings["nav"]
}

const { meta, t } = Astro.props
---

<nav class="nav">
  <div class="wrap nav-in">
    <a class="brand" href={meta.brandHref}><span class="dot"></span>Kevin Gámez</a>
    <div class="nav-links">
      <a href="#about">{t.about}</a>
      <a href="#experience">{t.experience}</a>
      <a href="#work">{t.work}</a>
      <a href="#github">{t.github}</a>
    </div>
    <div class="nav-right">
      <a class="lang" href={meta.langSwitchHref} hreflang={meta.langSwitchHreflang}
        ><Fragment set:html={meta.langSwitchLabelHtml} /></a
      >
      <a class="dev-toggle" href="/dev/"><span class="led"></span>{t.devMode}</a>
      <a class="say-hi" href="#contact">{t.sayHi}</a>
    </div>
  </div>
</nav>
