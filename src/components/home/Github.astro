---
import type { HomeStrings } from "@/content/home"

interface Props {
  t: HomeStrings["github"]
}

const { t } = Astro.props
---

<section id="github">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <div class="sec-num">{t.secNum}</div>
        <h2 class="sec-title"><Fragment set:html={t.titleHtml} /></h2>
      </div>
      <p class="sec-blurb">{t.blurb}</p>
    </div>
    <div class="gh-banner">
      <div class="gh-banner-cap">{t.snapshot}</div>
      <div class="gh-stats-row">
        <div class="gh-stat">
          <div class="gh-stat-num" data-target="28" data-format="plain">0</div>
          <div class="gh-stat-lbl">{t.publicRepos}</div>
          <div class="gh-stat-sub">{t.publicReposSub}</div>
        </div>
        <div class="gh-stat">
          <div class="gh-stat-num" data-target="8" data-format="plain">0</div>
          <div class="gh-stat-lbl">{t.languagesShipped}</div>
          <div class="gh-stat-sub">{t.languagesShippedSub}</div>
        </div>
        <div class="gh-stat">
          <div class="gh-stat-num" data-target="7" data-format="plain">0</div>
          <div class="gh-stat-lbl">{t.yearsOnGithub}</div>
          <div class="gh-stat-sub">{t.yearsOnGithubSub}</div>
        </div>
      </div>
      <div class="gh-langbar">
        <div class="gh-langbar-head">
          <span>{t.languageMix}</span>
          <span><b>{t.acrossPublicRepos}</b></span>
        </div>
        <div class="gh-langbar-track">
          <span class="gh-langbar-seg" data-pct="33" style="background:#3178c6"></span>
          <span class="gh-langbar-seg" data-pct="27" style="background:#3572A5"></span>
          <span class="gh-langbar-seg" data-pct="7" style="background:#F05138"></span>
          <span class="gh-langbar-seg" data-pct="7" style="background:#f1e05a"></span>
          <span class="gh-langbar-seg" data-pct="7" style="background:#00B4AB"></span>
          <span class="gh-langbar-seg" data-pct="7" style="background:#384d54"></span>
          <span class="gh-langbar-seg" data-pct="7" style="background:#563d7c"></span>
          <span class="gh-langbar-seg" data-pct="5" style="background:#DA5B0B"></span>
        </div>
        <div class="gh-langbar-legend">
          <span><i style="background:#3178c6"></i>TypeScript · 33%</span>
          <span><i style="background:#3572A5"></i>Python · 27%</span>
          <span><i style="background:#F05138"></i>Swift · 7%</span>
          <span><i style="background:#f1e05a"></i>JavaScript · 7%</span>
          <span><i style="background:#00B4AB"></i>Dart · 7%</span>
          <span><i style="background:#384d54"></i>Dockerfile · 7%</span>
          <span><i style="background:#563d7c"></i>CSS · 7%</span>
          <span><i style="background:#DA5B0B"></i>Jupyter · 5%</span>
        </div>
      </div>
    </div>
    <div class="gh-grid">
      <div class="gh-card">
        <div class="gh-card-head">
          <h3>{t.contributionsTitle}</h3>
          <span class="num">{t.last12Months}</span>
        </div>
        <div class="contrib-frame">
          <div class="contrib-months" aria-hidden="true">
            {t.months.map((m) => <span>{m}</span>)}
          </div>
          <div class="contrib-dows" aria-hidden="true">
            {t.dows.map((d, i) => <span class={i % 2 === 0 ? "hide" : ""}>{d}</span>)}
          </div>
          <div class="contrib" id="contrib-graph"></div>
        </div>
        <div class="contrib-legend">
          <span>{t.less}</span>
          <span class="scale">
            <span style="background:var(--cream-3)"></span>
            <span style="background:#f5cdb8"></span>
            <span style="background:#ec9978"></span>
            <span style="background:#df764f"></span>
            <span style="background:var(--coral)"></span>
          </span>
          <span>{t.more}</span>
        </div>
        <div class="contrib-stats">
          <div class="cs">
            <div class="cs-num coral" id="contrib-total">0</div>
            <div class="cs-lbl">{t.statCommits}</div>
          </div>
          <div class="cs">
            <div class="cs-num" id="contrib-current">0</div>
            <div class="cs-lbl">{t.statCurrent}</div>
          </div>
          <div class="cs">
            <div class="cs-num" id="contrib-longest">0</div>
            <div class="cs-lbl">{t.statLongest}</div>
          </div>
        </div>
      </div>
      <div>
        <div class="repos">
          <a class="repo" href="https://github.com/kevingamez/personal-site" target="_blank" rel="noopener">
            <div>
              <div class="nm">kevingamez / personal-site</div>
              <div class="desc">{t.repoSiteDesc}</div>
            </div>
            <div class="stat">
              <span><span class="lang" style="background:#3178c6"></span>TypeScript</span>
            </div>
          </a>
          <a
            href="https://github.com/kevingamez/AD_ASTRA2023-SpaceInvaders"
            class="repo"
            target="_blank"
            rel="noopener"
          >
            <div>
              <div class="nm">kevingamez / AD_ASTRA2023-SpaceInvaders</div>
              <div class="desc">{t.repoSpaceDesc}</div>
            </div>
            <div class="stat">
              <span><span class="lang" style="background:#3572A5"></span>Python</span>
            </div>
          </a>
          <a href="https://github.com/kevingamez/Palladium_Chat" class="repo" target="_blank" rel="noopener">
            <div>
              <div class="nm">kevingamez / Palladium_Chat</div>
              <div class="desc">{t.repoChatDesc}</div>
            </div>
            <div class="stat">
              <span><span class="lang" style="background:#3178c6"></span>TypeScript</span>
            </div>
          </a>
          <a href="https://github.com/kevingamez/budget-app" class="repo" target="_blank" rel="noopener">
            <div>
              <div class="nm">kevingamez / budget-app</div>
              <div class="desc">{t.repoBudgetDesc}</div>
            </div>
            <div class="stat">
              <span><span class="lang" style="background:#F05138"></span>Swift</span>
            </div>
          </a>
          <a href="https://github.com/kevingamez/GCP-CloudRun" class="repo" target="_blank" rel="noopener">
            <div>
              <div class="nm">kevingamez / GCP-CloudRun</div>
              <div class="desc">{t.repoCloudDesc}</div>
            </div>
            <div class="stat">
              <span><span class="lang" style="background:#384d54"></span>Dockerfile</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
