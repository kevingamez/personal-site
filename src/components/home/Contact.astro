---
import type { HomeStrings } from "@/content/home"

interface Props {
  t: HomeStrings["contact"]
}

const { t } = Astro.props
---

<section id="contact" class="contact">
  <div class="wrap">
    <h2><Fragment set:html={t.titleHtml} /></h2>
    <p>{t.body}</p>
    <div class="contact-cta">
      <a class="btn btn-primary" href="mailto:kevingamez.kg@gmail.com">{t.btnEmail}</a>
      <a class="btn btn-ghost" href="/dev">{t.btnDev}</a>
    </div>
    <div class="contact-channels">
      <a href="https://github.com/kevingamez" target="_blank" rel="noopener">github / kevingamez</a>
      <a href="https://x.com/kevin_gamez" target="_blank" rel="noopener">x / kevin_gamez</a>
      <a href="https://www.linkedin.com/in/kevin-gamez/" target="_blank" rel="noopener">linkedin / kevingamez</a>
    </div>
  </div>
</section>
