---
import type { HomeStrings } from "@/content/home"

interface Props {
  t: HomeStrings["footer"]
  buildId: string
}

const { t, buildId } = Astro.props
---

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <h3>{t.h4Page}</h3>
        <div class="col-name">Kevin <i>Gámez</i></div>
        <p>{t.pBlurb}</p>
      </div>
      <div>
        <h3>{t.h4Sections}</h3>
        <ul>
          <li><a href="#about">{t.sectionsAbout}</a></li>
          <li><a href="#experience">{t.sectionsExperience}</a></li>
          <li><a href="#github">{t.sectionsGithub}</a></li>
        </ul>
      </div>
      <div>
        <h3>{t.h4Elsewhere}</h3>
        <ul>
          <li><a href="https://github.com/kevingamez" target="_blank" rel="noopener">github</a></li>
          <li><a href="https://x.com/KevinGamezA" target="_blank" rel="noopener">x</a></li>
          <li><a href="https://co.linkedin.com/in/kevin-gamez/" target="_blank" rel="noopener">linkedin</a></li>
          <li><a href="https://www.strava.com/athletes/70612862" target="_blank" rel="noopener">strava</a></li>
          <li><a href="/dev/">{t.elsewhereDev}</a></li>
        </ul>
      </div>
    </div>
    <div class="colophon">
      <span><Fragment set:html={t.fonts} /></span>
      <span>v14.2 · build {buildId}</span>
      <span>{t.estab}</span>
    </div>
  </div>
</footer>
