---
import type { HomeStrings } from "@/content/home"

interface Props {
  t: HomeStrings["skills"]
}

const { t } = Astro.props
---

<section id="skills">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <div class="sec-num">{t.secNum}</div>
        <h2 class="sec-title"><Fragment set:html={t.titleHtml} /></h2>
      </div>
      <p class="sec-blurb">{t.blurb}</p>
    </div>
    <div class="skill-cluster">
      <div class="label">{t.languages}</div>
      <div class="chips">
        <span class="chip hot">TypeScript</span>
        <span class="chip hot">Python</span>
        <span class="chip">Swift</span>
        <span class="chip">JavaScript</span>
        <span class="chip">Java</span>
        <span class="chip">Dart</span>
        <span class="chip">SQL</span>
        <span class="chip">Bash</span>
      </div>
    </div>
    <div class="skill-cluster">
      <div class="label">{t.frontend}</div>
      <div class="chips">
        <span class="chip hot">React</span>
        <span class="chip hot">Next.js</span>
        <span class="chip">React Native</span>
        <span class="chip">Astro</span>
        <span class="chip">Tailwind</span>
        <span class="chip">SwiftUI</span>
        <span class="chip">Flutter</span>
      </div>
    </div>
    <div class="skill-cluster">
      <div class="label"><Fragment set:html={t.backend} /></div>
      <div class="chips">
        <span class="chip hot">PostgreSQL</span>
        <span class="chip hot">Prisma</span>
        <span class="chip hot">NestJS</span>
        <span class="chip">Node.js</span>
        <span class="chip">Supabase</span>
        <span class="chip">Inngest</span>
        <span class="chip">FastAPI</span>
        <span class="chip">Docker</span>
        <span class="chip">Vercel</span>
        <span class="chip">AWS · GCP</span>
      </div>
    </div>
    <div class="skill-cluster">
      <div class="label">{t.ai}</div>
      <div class="chips">
        <span class="chip hot">OpenAI</span>
        <span class="chip hot">Browser automation</span>
        <span class="chip">{t.chips.llmPipelines}</span>
        <span class="chip">Anthropic SDK</span>
        <span class="chip">PyTorch</span>
        <span class="chip">OpenCV</span>
        <span class="chip">YOLO</span>
      </div>
    </div>
    <div class="skill-cluster">
      <div class="label"><Fragment set:html={t.data} /></div>
      <div class="chips">
        <span class="chip">{t.chips.sqlModeling}</span>
        <span class="chip">Power BI</span>
        <span class="chip">{t.chips.etlPipelines}</span>
      </div>
    </div>
  </div>
</section>
