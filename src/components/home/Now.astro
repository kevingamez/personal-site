---
import type { HomeStrings } from "@/content/home"

interface Props {
  t: HomeStrings["now"]
}

const { t } = Astro.props
---

<section id="now">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <div class="sec-num">{t.secNum}</div>
        <h2 class="sec-title"><Fragment set:html={t.titleHtml} /></h2>
      </div>
      <p class="sec-blurb">{t.blurb}</p>
    </div>
    <div class="now-grid">
      <div class="now-cell">
        <div class="k">{t.buildingK}</div>
        <div class="v"><Fragment set:html={t.buildingV} /></div>
        <div class="sub">{t.buildingSub}</div>
      </div>
      <div class="now-cell">
        <div class="k">{t.readingK}</div>
        <div class="v">{t.readingV}</div>
        <div class="sub">{t.readingSub}</div>
      </div>
      <div class="now-cell">
        <div class="k">{t.listeningK}</div>
        <div class="v"><Fragment set:html={t.listeningV} /></div>
        <div class="sub">{t.listeningSub}</div>
      </div>
      <div class="now-cell">
        <div class="k">{t.thinkingK}</div>
        <div class="v">{t.thinkingV}</div>
        <div class="sub">{t.thinkingSub}</div>
      </div>
    </div>
  </div>
</section>
