---
import { loadHomeStats } from "@/data/home-github"
import { loadRecentCommits } from "@/data/dev-github"

// Same source of truth as the public-facing GitHub section on / — counts,
// language mix and top repos are all live from the GraphQL/REST API at
// build time (with disk cache).
const stats = await loadHomeStats()

// Real recent commits feed (PushEvents across public repos, 6h cache).
const recentCommits = (await loadRecentCommits()).slice(0, 6)
const tailTime = (iso: string): string => {
  const d = new Date(iso)
  const hh = String(d.getUTCHours()).padStart(2, "0")
  const mm = String(d.getUTCMinutes()).padStart(2, "0")
  return `${hh}:${mm}`
}

// Format "joined Apr 2019" from the ISO date.
const joinedLabel = (() => {
  if (!stats.joinedISO) return ""
  const d = new Date(stats.joinedISO)
  const month = d.toLocaleString("en-US", { month: "short" })
  return `joined ${month} ${d.getFullYear()}`
})()

// Top language bars - height scales relative to the leading slice (so the
// tallest bar is always 99%, rest scale down). Mirrors the spark mix shown
// on the home page.
const topLang = stats.languageMix[0]?.pct || 1
const langBars = stats.languageMix.slice(0, 8).map((l) => ({
  name: l.name,
  pct: l.pct,
  color: l.color,
  height: Math.max(15, Math.round((l.pct / topLang) * 99)),
}))

// Top repos - link out to github.com. Limit to 4 to fit the sidebar.
const featured = stats.topRepos.slice(0, 4).map((r) => {
  const tag = r.language === "TypeScript" ? "TS" : r.language === "JavaScript" ? "JS" : r.language
  return { name: r.name, color: r.color, tag, url: r.url }
})
---

<aside class="sidebar">
  <div class="panel">
    <div class="ph"><b>github · @kevingamez</b><span class="pos">live</span></div>
    <div class="row2">
      <div class="metric">
        <div class="vl">{stats.publicRepos}<span> repos</span></div>
        <div class="sub">{stats.followers} followers · {stats.following} following</div>
      </div>
      <div class="metric">
        <div class="vl">{stats.yearsOnGithub}<span> yrs</span></div>
        <div class="sub">{joinedLabel}</div>
      </div>
    </div>
    <div class="spark" id="spark" aria-label="Language mix across public repos">
      {langBars.map((l) => <span style={`height:${l.height}%;background:${l.color}`} title={`${l.name} ${l.pct}%`} />)}
    </div>
  </div>

  <div class="panel">
    <div class="ph"><b>in flight</b><span class="pos">2026</span></div>
    <div class="flight-list">
      <a
        class="flight-row"
        href="https://www.enttor.ai/"
        target="_blank"
        rel="noopener"
        title="Enttor — ai outbound platform"
      >
        <span class="fl-num">01</span>
        <div class="fl-body">
          <div class="fl-title">ai outbound · <span class="fl-where">enttor</span></div>
          <div class="fl-meta">browser automation · openai pipelines · ig/linkedin</div>
        </div>
        <span class="fl-status fl-live">live</span>
      </a>
      <a
        class="flight-row"
        href="https://github.com/kevingamez/personal-site"
        target="_blank"
        rel="noopener"
        title="kevingamez/personal-site"
      >
        <span class="fl-num">02</span>
        <div class="fl-body">
          <div class="fl-title">this site · <span class="fl-where">open source</span></div>
          <div class="fl-meta">astro · typescript · live console + dev mode</div>
        </div>
        <span class="fl-status fl-ship">ship</span>
      </a>
      <a
        class="flight-row"
        href="https://github.com/kevingamez/AD_ASTRA2023-SpaceInvaders"
        target="_blank"
        rel="noopener"
        title="AD ASTRA · aerial deforestation detection"
      >
        <span class="fl-num">03</span>
        <div class="fl-body">
          <div class="fl-title">AD_ASTRA · <span class="fl-where">m.sc. thesis</span></div>
          <div class="fl-meta">python · opencv · yolov5 · fastapi · amazon basin</div>
        </div>
        <span class="fl-status fl-research">research</span>
      </a>
    </div>
  </div>

  <div class="panel">
    <div class="ph"><b>tail -f /var/log/commits</b><span class="pos">github · live</span></div>
    <div class="reqs commit-tail" id="reqs">
      {
        recentCommits.length === 0 && (
          <div class="r" style="color:var(--mute-2)">no recent push events</div>
        )
      }
      {
        recentCommits.map((c) => (
          <a class="r commit-r" href={c.url} target="_blank" rel="noopener">
            <span class="ts">{tailTime(c.ts)}</span>
            <span class="sha">{c.shaShort}</span>
            <span class="pa">
              <span class="ct-repo">{c.repoShort}</span>
              <span class="ct-msg">{c.message}</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>

  <div class="panel">
    <div class="ph"><b>contributions · 12mo</b><span class="pos">github</span></div>
    <div class="hm" id="hm" data-contrib={JSON.stringify(stats.contribCalendar.days.map((d) => d.level))}></div>
    <div class="hm-legend">
      <span>12mo ago</span>
      <span class="hm-total">{stats.contribCalendar.totalContributions.toLocaleString()} contributions</span>
      <span>today</span>
    </div>
  </div>

  <div class="panel">
    <div class="ph"><b>open source</b><span class="pos">@kevingamez</span></div>
    <div class="repos">
      {
        featured.map((r) => (
          <a href={r.url} target="_blank" rel="noopener">
            <span>
              <span class="lg" style={`background:${r.color}`} />
              {r.name}
            </span>
            <span class="star">{r.tag}</span>
          </a>
        ))
      }
    </div>
  </div>

  <div class="panel">
    <div class="ph"><b>now() →</b></div>
    <div style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;line-height:1.7;color:var(--ink-2)">
      <div><span class="ac">building</span> · ai outbound @ enttor</div>
      <div><span class="ac">stack</span> · next.js + nestjs + postgres</div>
      <div><span class="ac">studying</span> · deep learning, browser automation</div>
      <div><span class="ac">based</span> · bogotá, co · utc-5</div>
    </div>
  </div>
</aside>
