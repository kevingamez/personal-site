---
// Settings panel for the /dev activity bar. Real-time theme switching (4
// presets), font-size slider, motion preference, sound toggle. Persists to
// localStorage so the user's choice survives reloads.
---

<aside id="settings" class="settings-panel" hidden>
  <header class="st-head">
    <div class="st-title">Settings</div>
    <div class="st-sub">Live · saved to this browser</div>
  </header>

  <section class="st-block">
    <div class="st-label">Theme</div>
    <div class="st-themes" role="radiogroup" aria-label="Theme">
      <button
        class="st-theme on"
        data-theme="cream"
        role="radio"
        aria-checked="true"
        title="Cream (editorial · default)"
      >
        <div class="st-swatch" style="background:linear-gradient(135deg,#faf7f0 0%,#ebe3d4 50%,#d96944 100%)"></div>
        <span>Cream</span>
      </button>
      <button class="st-theme" data-theme="midnight" role="radio" aria-checked="false" title="Midnight">
        <div class="st-swatch" style="background:linear-gradient(135deg,#0d0d14 0%,#1f1d2a 60%,#6b8eff 100%)"></div>
        <span>Midnight</span>
      </button>
      <button class="st-theme" data-theme="sepia" role="radio" aria-checked="false" title="Sepia">
        <div class="st-swatch" style="background:linear-gradient(135deg,#f3e4cb 0%,#c2a085 60%,#7a4a2a 100%)"></div>
        <span>Sepia</span>
      </button>
      <button class="st-theme" data-theme="solar" role="radio" aria-checked="false" title="Solar">
        <div class="st-swatch" style="background:linear-gradient(135deg,#fff4d9 0%,#ffb066 60%,#d9483a 100%)"></div>
        <span>Solar</span>
      </button>
    </div>
  </section>

  <section class="st-block">
    <div class="st-label">Editor font size</div>
    <div class="st-row">
      <input id="st-fontsize" type="range" min="11" max="16" step="0.5" value="13" />
      <output for="st-fontsize" id="st-fontsize-out">13px</output>
    </div>
  </section>

  <section class="st-block">
    <div class="st-label">Cursor</div>
    <div class="st-segment" role="radiogroup" aria-label="Cursor">
      <button class="st-seg on" data-cursor="block" role="radio" aria-checked="true">Block</button>
      <button class="st-seg" data-cursor="bar" role="radio" aria-checked="false">Bar</button>
      <button class="st-seg" data-cursor="underline" role="radio" aria-checked="false">Underline</button>
    </div>
  </section>

  <section class="st-block">
    <div class="st-label">Preferences</div>
    <label class="st-switch">
      <input type="checkbox" id="st-motion" />
      <span class="st-switch-track"><span class="st-switch-thumb"></span></span>
      <span class="st-switch-text">Reduce motion</span>
    </label>
    <label class="st-switch">
      <input type="checkbox" id="st-sound" />
      <span class="st-switch-track"><span class="st-switch-thumb"></span></span>
      <span class="st-switch-text">Keypress sounds</span>
    </label>
  </section>

  <section class="st-block st-shortcuts">
    <div class="st-label">Shortcuts</div>
    <div class="st-kbd-row"><span>Command palette</span><kbd>⌘P</kbd></div>
    <div class="st-kbd-row"><span>Save file</span><kbd>⌘S</kbd></div>
    <div class="st-kbd-row"><span>Toggle explorer</span><kbd>⌃B</kbd></div>
    <div class="st-kbd-row"><span>Exit dev mode</span><kbd>⎋</kbd></div>
  </section>

  <button class="st-reset" id="st-reset" type="button">
    <span class="material-symbols-outlined">refresh</span>
    <span>Reset to defaults</span>
  </button>
</aside>
