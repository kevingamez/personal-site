---
import { formatBogotaTime } from "@/scripts/clock"
interface Props {
  buildId: string
}
const { buildId } = Astro.props
---

<div class="titlebar">
  <div class="l">
    <div class="dots"><span></span><span></span><span></span></div>
    <div class="ttl">kevin@gamez · <b>~/dev</b> · 1452 × 902</div>
  </div>
  <div class="r">
    <span><span class="led"></span>live · build {buildId}</span>
    <a class="back" href="/">← exit dev mode</a>
  </div>
</div>

<div class="tabsbar">
  <div class="tab on" data-ws="workspace"><span class="num">1</span>workspace</div>
  <div class="tab muted" data-ws="scratchpad"><span class="num">2</span>scratchpad</div>
  <div class="tab muted" data-ws="changelog"><span class="num">3</span>changelog</div>
  <div class="grow"></div>
  <div class="live">utc-5 · bogotá · <b data-bogota-clock>{formatBogotaTime()}</b></div>
</div>
