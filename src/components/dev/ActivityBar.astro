<aside class="activity-bar">
  <button class="ab-item on" data-ab="explorer" title="Explorer (⌃B)" aria-label="Explorer">
    <span class="material-symbols-outlined">folder_open</span>
  </button>
  <button class="ab-item" data-ab="search" title="Search (⌘P)" aria-label="Search">
    <span class="material-symbols-outlined">search</span>
  </button>
  <button class="ab-item" data-ab="source-control" title="Source control" aria-label="Source control">
    <span class="material-symbols-outlined">commit</span>
  </button>
  <button class="ab-item" data-ab="extensions" title="Extensions" aria-label="Extensions">
    <span class="material-symbols-outlined">extension</span>
  </button>
  <div class="ab-grow"></div>
  <button class="ab-item" data-ab="profile" title="Profile" aria-label="Profile">
    <span class="material-symbols-outlined">account_circle</span>
  </button>
  <button class="ab-item" data-ab="settings" title="Settings" aria-label="Settings">
    <span class="material-symbols-outlined">settings</span>
  </button>
</aside>
